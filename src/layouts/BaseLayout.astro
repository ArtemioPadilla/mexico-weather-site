---
import FeedbackFAB from '../components/common/FeedbackFAB.astro';
import ThemeToggle from '../components/common/ThemeToggle.astro';
import { siteBase } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'es' | 'en';
  image?: string;
  robots?: string;
}

const base = siteBase();
// Raster OG image (1200x630 PNG) — social crawlers reject SVG, so this must be
// an absolute URL to a real PNG. Resolves to
// https://artemiop.com/mexico-weather/og-image.png
const defaultImage = new URL(`${base}og-image.png`, Astro.site).href;

// Error-monitoring is opt-in: completely inert unless PUBLIC_SENTRY_DSN is set
// at build time. With no DSN (the default) nothing is rendered.
const sentryDsn = import.meta.env.PUBLIC_SENTRY_DSN;

const {
  title = 'Clima México',
  description = 'Pronósticos y alertas meteorológicas para México',
  lang = 'es',
  image = defaultImage,
  robots = 'index,follow',
} = Astro.props;

// Absolute canonical URL for the current page (Astro.site + current pathname).
// Ensure a trailing slash on the path to match sitemap <loc> directory-style URLs.
const rawPathname = Astro.url.pathname;
const normalizedPathname = rawPathname.endsWith('/') ? rawPathname : `${rawPathname}/`;
const canonical = new URL(normalizedPathname, Astro.site).href;
const ogLocale = lang === 'es' ? 'es_MX' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonical} />
    {/* Anti-FOUC: resolver y aplicar el tema antes del primer pintado. */}
    <script is:inline>
      (function () {
        var pref;
        // Key MUST match THEME_STORAGE_KEY in src/lib/theme.ts (inline script cannot import).
        try { pref = localStorage.getItem('theme'); } catch (e) { pref = null; }
        if (pref !== 'light' && pref !== 'dark' && pref !== 'system') {
          pref = 'system';
        }
        var prefersDark =
          window.matchMedia &&
          window.matchMedia('(prefers-color-scheme: dark)').matches;
        var dark = pref === 'dark' || (pref !== 'light' && prefersDark);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>

    {/*
     * Register our OWN scoped service worker so the weather pages are
     * permanently isolated from the parent user site's root-scoped PWA
     * service worker (https://artemiop.com/sw.js, scope "/"). The browser
     * gives control of a client to the most specifically-scoped
     * registration, so a worker scoped to /mexico-weather/ always wins
     * over the parent "/". This is purely an enhancement: every statement is
     * wrapped in try/catch and deferred to `load`, so any failure is inert
     * and never blocks rendering.
     */}
    <script is:inline define:vars={{ base }}>
      (function () {
        try {
          if (!('serviceWorker' in navigator)) return;
          // base is import.meta.env.BASE_URL normalized with a trailing
          // slash (siteBase()), e.g. "/mexico-weather/".
          var swUrl = new URL(base + 'sw.js', location.origin).href;

          // One-shot migration guard. If a stale OTHER SW currently controls
          // this page — either the PARENT root SW (scope "/", script
          // "/sw.js") OR the OLD pre-rename worker still scoped to the
          // previous base ("/mexico-weather-site/sw.js", left behind after
          // the GitHub repo rename) — swapping in our worker requires exactly
          // ONE reload to put the page under fresh control. This
          // sessionStorage flag is checked FIRST and set BEFORE any reload,
          // so at most one migration reload can ever happen per browsing
          // session — it cannot loop even if controllerchange fires
          // repeatedly.
          var MIGRATED_KEY = 'secid-sw-migrated';
          var alreadyMigrated = false;
          try {
            alreadyMigrated =
              sessionStorage.getItem(MIGRATED_KEY) === '1';
          } catch (e) {
            // sessionStorage unavailable (private mode / blocked). Treat as
            // "already migrated" so we NEVER reload without a working guard.
            alreadyMigrated = true;
          }

          // Is the page currently controlled by some OTHER SW (any SW whose
          // script is NOT our current sw.js)? Two cases qualify:
          //   1. the PARENT root worker at "/sw.js" (scope "/"); and
          //   2. the OLD pre-rename worker at "/mexico-weather-site/sw.js"
          //      — after the repo rename the base moved to "/mexico-weather/"
          //      so the previously-scoped worker is now stale "other" too.
          // Both end with "/sw.js" and differ from our new swUrl, so the
          // single endsWith/!=swUrl test below covers them uniformly. Only
          // then is a migration reload meaningful. If uncontrolled or already
          // controlled by us (scriptURL === swUrl): nothing.
          var controller = navigator.serviceWorker.controller;
          var controlledByOther =
            !!controller &&
            typeof controller.scriptURL === 'string' &&
            controller.scriptURL.indexOf('/sw.js') !== -1 &&
            controller.scriptURL !== swUrl;

          window.addEventListener('load', function () {
            navigator.serviceWorker
              .register(swUrl, { scope: base })
              .then(function () {
                if (!controlledByOther || alreadyMigrated) return;
                navigator.serviceWorker.addEventListener(
                  'controllerchange',
                  function onChange() {
                    navigator.serviceWorker.removeEventListener(
                      'controllerchange',
                      onChange
                    );
                    var blocked = false;
                    try {
                      // Set the guard BEFORE reloading. On the next load
                      // alreadyMigrated is true, so this branch is skipped
                      // forever this session: a single reload, never a loop.
                      sessionStorage.setItem(MIGRATED_KEY, '1');
                    } catch (e) {
                      // Cannot persist the guard → do NOT reload, since an
                      // unguarded reload could loop. Safe: our SW still
                      // controls subsequent navigations.
                      blocked = true;
                    }
                    if (!blocked) location.reload();
                  }
                );
              })
              .catch(function () {
                /* registration failed — enhancement only, ignore */
              });
          });
        } catch (e) {
          /* never let SW isolation break the page */
        }
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Clima México" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
  </head>
  <body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased">
    {/*
     * Slim sticky topbar (closes #93). Sits above any in-page absolute
     * controls (MapLibre uses z-10..z-20 on /mapa). position:sticky (not
     * fixed) so the page below — including the /mapa MapLibre canvas —
     * still claims the full viewport below the bar. backdrop-blur +
     * translucent bg let map/forecast content show through subtly.
     */}
    <nav
      aria-label="Principal"
      class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/60 dark:border-gray-800 dark:bg-gray-900/80 dark:supports-[backdrop-filter]:bg-gray-900/60"
      style="padding-top:env(safe-area-inset-top)"
    >
      <div class="mx-auto flex h-12 max-w-6xl items-center justify-between gap-3 px-3 sm:h-14 sm:px-4">
        <a
          href={base}
          class="flex items-center gap-2 text-sm font-semibold text-gray-900 hover:text-blue-600 dark:text-gray-100 dark:hover:text-blue-400"
        >
          <span aria-hidden="true" class="text-base leading-none">🇲🇽</span>
          <span>Clima México</span>
        </a>
        <div class="flex items-center gap-1 sm:gap-2">
          <a
            href={base}
            class="rounded-md px-2 py-1 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
            >Inicio</a
          >
          <a
            href={`${base}mapa`}
            class="rounded-md px-2 py-1 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
            >Mapa</a
          >
          <ThemeToggle lang={lang} />
        </div>
      </div>
    </nav>
    <slot />
    <FeedbackFAB lang={lang} />
    {
      /*
       * Opt-in error monitoring. This block renders NOTHING unless
       * PUBLIC_SENTRY_DSN is provided at build time, so there is zero runtime
       * behavior and no network activity by default. When a DSN is set, the
       * Sentry browser CDN bundle is lazy-loaded and initialized.
       */
    }
    {
      sentryDsn && (
        <Fragment>
          <script
            is:inline
            src="https://browser.sentry-cdn.com/8.40.0/bundle.min.js"
            crossorigin="anonymous"
          />
          <script is:inline define:vars={{ sentryDsn }}>
            window.addEventListener('load', function () {
              if (window.Sentry) {
                window.Sentry.init({ dsn: sentryDsn });
              }
            });
          </script>
        </Fragment>
      )
    }
  </body>
</html>
