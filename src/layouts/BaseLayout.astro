---
import FeedbackFAB from '../components/common/FeedbackFAB.astro';
import LanguageToggle from '../components/common/LanguageToggle.astro';
import PwaInstall from '../components/common/PwaInstall.astro';
import SmnAlertRibbon from '../components/SmnAlertRibbon.astro';
import ThemeToggle from '../components/common/ThemeToggle.astro';
import { siteBase } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Optional English overrides for title + description. When the
   *  user has chosen English via ?lang=en or the toggle, the
   *  inline pre-paint script swaps document.title and the
   *  description/og meta tags to these values. */
  titleEn?: string;
  descriptionEn?: string;
  lang?: 'es' | 'en';
  image?: string;
  robots?: string;
  /** Optional JSON-LD payload(s) for schema.org structured data.
   *  Emitted as <script type="application/ld+json"> in <head>. Use
   *  builders from src/lib/structured-data.ts so the shape matches
   *  schema.org. */
  jsonLd?: object | object[];
}

const base = siteBase();
// Raster OG image (1200x630 PNG) — social crawlers reject SVG, so this must be
// an absolute URL to a real PNG. Resolves to
// https://artemiop.com/mexico-weather/og-image.png
const defaultImage = new URL(`${base}og-image.png`, Astro.site).href;

// Error-monitoring is opt-in: completely inert unless PUBLIC_SENTRY_DSN is set
// at build time. With no DSN (the default) nothing is rendered.
const sentryDsn = import.meta.env.PUBLIC_SENTRY_DSN;

const {
  title = 'Clima México',
  description = 'Pronósticos y alertas meteorológicas para México',
  titleEn,
  descriptionEn,
  lang = 'es',
  image = defaultImage,
  robots = 'index,follow',
  jsonLd,
} = Astro.props;

const jsonLdEntries = jsonLd === undefined
  ? []
  : Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd];

// Absolute canonical URL for the current page (Astro.site + current pathname).
// Ensure a trailing slash on the path to match sitemap <loc> directory-style URLs.
const rawPathname = Astro.url.pathname;
const normalizedPathname = rawPathname.endsWith('/') ? rawPathname : `${rawPathname}/`;
const canonical = new URL(normalizedPathname, Astro.site).href;
const ogLocale = lang === 'es' ? 'es_MX' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description}
      data-i18n-en-content={descriptionEn}
    />
    <meta name="robots" content={robots} />
    <title data-i18n-en={titleEn}>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}favicon.svg`} />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="theme-color" content="#0a0e1a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Clima MX" />
    <link rel="canonical" href={canonical} />
    {/* hreflang (Story 6.3) — query-param strategy.
        The Spanish version is the canonical (no param). The English
        version lives at the same URL with ?lang=en, where the
        BaseLayout pre-paint script (below) reads the param and
        swaps every data-i18n-en text node before first paint.
        Google supports query-param hreflang as long as the param
        produces distinct content. */}
    <link rel="alternate" hreflang="es-MX" href={canonical} />
    <link
      rel="alternate"
      hreflang="en-US"
      href={`${canonical}${canonical.includes('?') ? '&' : '?'}lang=en`}
    />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    {/* Anti-FOUC: resolver y aplicar el tema antes del primer pintado. */}
    <script is:inline>
      (function () {
        var pref;
        // Key MUST match THEME_STORAGE_KEY in src/lib/theme.ts (inline script cannot import).
        try { pref = localStorage.getItem('theme'); } catch (e) { pref = null; }
        if (pref !== 'light' && pref !== 'dark' && pref !== 'system') {
          pref = 'system';
        }
        var prefersDark =
          window.matchMedia &&
          window.matchMedia('(prefers-color-scheme: dark)').matches;
        var dark = pref === 'dark' || (pref !== 'light' && prefersDark);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
    {/* Story 6.1 — apply language preference before first paint.
        Reads sessionStorage mw:lang and updates html.lang + swaps
        every element with a data-i18n-en attribute to its English
        text. Inline so it runs before any user-visible content. */}
    <script is:inline>
      (function () {
        var lang;
        // Priority order: URL ?lang= param (Story 6.3 hreflang
        // landing) → sessionStorage → navigator.language → 'es'.
        // The URL param is intentionally NOT written to sessionStorage
        // — that would mean a Spanish-speaking user clicking a
        // shared ?lang=en link gets permanently flipped to English
        // for their whole session, with no obvious way back. The
        // user has to explicitly hit the toggle to persist a
        // preference. Per-page application only.
        try {
          var p = new URLSearchParams(window.location.search).get('lang');
          if (p === 'en' || p === 'es') {
            lang = p;
          }
        } catch (e) { /* SSR / no URLSearchParams */ }
        if (!lang) {
          try { lang = sessionStorage.getItem('mw:lang'); } catch (e) { lang = null; }
        }
        if (lang !== 'en' && lang !== 'es') {
          var nl = (navigator && navigator.language) || '';
          lang = nl.toLowerCase().indexOf('en') === 0 ? 'en' : 'es';
        }
        document.documentElement.lang = lang;
        document.documentElement.setAttribute('data-lang', lang);
        if (lang === 'en') {
          // Swap text nodes carrying data-i18n-en after DOM is parsed.
          var applyI18n = function () {
            // textContent swap (default — strips children).
            document.querySelectorAll('[data-i18n-en]').forEach(function (n) {
              var v = n.getAttribute('data-i18n-en');
              if (v) n.textContent = v;
            });
            // innerHTML swap (for mixed content with embedded <strong>,
            // <a>, etc.). The English HTML must be authored safely
            // in the data attribute — never user-input.
            document.querySelectorAll('[data-i18n-en-html]').forEach(function (n) {
              var v = n.getAttribute('data-i18n-en-html');
              if (v) n.innerHTML = v;
            });
            // Attribute swaps.
            document.querySelectorAll('[data-i18n-en-placeholder]').forEach(function (n) {
              var v = n.getAttribute('data-i18n-en-placeholder');
              if (v) n.setAttribute('placeholder', v);
            });
            document.querySelectorAll('[data-i18n-en-aria-label]').forEach(function (n) {
              var v = n.getAttribute('data-i18n-en-aria-label');
              if (v) n.setAttribute('aria-label', v);
            });
            document.querySelectorAll('[data-i18n-en-title]').forEach(function (n) {
              var v = n.getAttribute('data-i18n-en-title');
              if (v) n.setAttribute('title', v);
            });
            // <meta content> swap (description, og:title, og:description, ...).
            document.querySelectorAll('[data-i18n-en-content]').forEach(function (n) {
              var v = n.getAttribute('data-i18n-en-content');
              if (v) n.setAttribute('content', v);
            });
          };
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', applyI18n);
          } else {
            applyI18n();
          }
          // Skip-link target: every page that uses BaseLayout has a
          // single <main>. Stamp #main-content on the first one we
          // find so the skip link in the body has somewhere to land
          // without threading an id through every page template.
          var setSkipTarget = function () {
            var m = document.querySelector('main');
            if (m && !m.id) m.id = 'main-content';
          };
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', setSkipTarget);
          } else {
            setSkipTarget();
          }
          // Expose for runtime-generated content (the SMN widget,
          // /forecast templates, etc. can call window.__i18nApply()
          // after they inject HTML).
          /** @type {any} */ (window).__i18nApply = applyI18n;
        }
      })();
    </script>

    {/*
     * Register our OWN scoped service worker so the weather pages are
     * permanently isolated from the parent user site's root-scoped PWA
     * service worker (https://artemiop.com/sw.js, scope "/"). The browser
     * gives control of a client to the most specifically-scoped
     * registration, so a worker scoped to /mexico-weather/ always wins
     * over the parent "/". This is purely an enhancement: every statement is
     * wrapped in try/catch and deferred to `load`, so any failure is inert
     * and never blocks rendering.
     */}
    <script is:inline define:vars={{ base }}>
      (function () {
        try {
          if (!('serviceWorker' in navigator)) return;
          // base is import.meta.env.BASE_URL normalized with a trailing
          // slash (siteBase()), e.g. "/mexico-weather/".
          var swUrl = new URL(base + 'sw.js', location.origin).href;

          // One-shot migration guard. If a stale OTHER SW currently controls
          // this page — either the PARENT root SW (scope "/", script
          // "/sw.js") OR the OLD pre-rename worker still scoped to the
          // previous base ("/mexico-weather-site/sw.js", left behind after
          // the GitHub repo rename) — swapping in our worker requires exactly
          // ONE reload to put the page under fresh control. This
          // sessionStorage flag is checked FIRST and set BEFORE any reload,
          // so at most one migration reload can ever happen per browsing
          // session — it cannot loop even if controllerchange fires
          // repeatedly.
          var MIGRATED_KEY = 'secid-sw-migrated';
          var alreadyMigrated = false;
          try {
            alreadyMigrated =
              sessionStorage.getItem(MIGRATED_KEY) === '1';
          } catch (e) {
            // sessionStorage unavailable (private mode / blocked). Treat as
            // "already migrated" so we NEVER reload without a working guard.
            alreadyMigrated = true;
          }

          // Is the page currently controlled by some OTHER SW (any SW whose
          // script is NOT our current sw.js)? Two cases qualify:
          //   1. the PARENT root worker at "/sw.js" (scope "/"); and
          //   2. the OLD pre-rename worker at "/mexico-weather-site/sw.js"
          //      — after the repo rename the base moved to "/mexico-weather/"
          //      so the previously-scoped worker is now stale "other" too.
          // Both end with "/sw.js" and differ from our new swUrl, so the
          // single endsWith/!=swUrl test below covers them uniformly. Only
          // then is a migration reload meaningful. If uncontrolled or already
          // controlled by us (scriptURL === swUrl): nothing.
          var controller = navigator.serviceWorker.controller;
          var controlledByOther =
            !!controller &&
            typeof controller.scriptURL === 'string' &&
            controller.scriptURL.indexOf('/sw.js') !== -1 &&
            controller.scriptURL !== swUrl;

          window.addEventListener('load', function () {
            navigator.serviceWorker
              .register(swUrl, { scope: base })
              .then(function () {
                if (!controlledByOther || alreadyMigrated) return;
                navigator.serviceWorker.addEventListener(
                  'controllerchange',
                  function onChange() {
                    navigator.serviceWorker.removeEventListener(
                      'controllerchange',
                      onChange
                    );
                    var blocked = false;
                    try {
                      // Set the guard BEFORE reloading. On the next load
                      // alreadyMigrated is true, so this branch is skipped
                      // forever this session: a single reload, never a loop.
                      sessionStorage.setItem(MIGRATED_KEY, '1');
                    } catch (e) {
                      // Cannot persist the guard → do NOT reload, since an
                      // unguarded reload could loop. Safe: our SW still
                      // controls subsequent navigations.
                      blocked = true;
                    }
                    if (!blocked) location.reload();
                  }
                );
              })
              .catch(function () {
                /* registration failed — enhancement only, ignore */
              });
          });
        } catch (e) {
          /* never let SW isolation break the page */
        }
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} data-i18n-en-content={titleEn} />
    <meta
      property="og:description"
      content={description}
      data-i18n-en-content={descriptionEn}
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Clima México" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} data-i18n-en-content={titleEn} />
    <meta
      name="twitter:description"
      content={description}
      data-i18n-en-content={descriptionEn}
    />
    <meta name="twitter:image" content={image} />

    {
      jsonLdEntries.map((entry) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(entry).replace(/</g, '\\u003c')}
        />
      ))
    }
  </head>
  <body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased">
    {/* Skip link — sr-only by default, visible on focus. Keyboard
        users skip the ~30-link top nav and land directly on the
        page's main content. Every page that uses BaseLayout has a
        single <main> with the implicit `main` landmark; we target it
        with href="#main" + an id added below by the runtime so we
        don't have to thread an id through every page template. */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-3 focus:top-3 focus:z-[100] focus:rounded-md focus:bg-blue-600 focus:px-3 focus:py-2 focus:text-sm focus:font-medium focus:text-white focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-white"
      data-i18n-en="Skip to main content"
    >Saltar al contenido principal</a>
    {/* Site-wide alert ribbon for critical national SMN avisos.
        Renders as a slim red bar ABOVE the sticky nav so it's
        impossible to miss. Hidden by default; the runtime script
        in SmnAlertRibbon.astro shows it only when there's an active
        critical aviso the user hasn't dismissed this session. */}
    <SmnAlertRibbon />
    {/*
     * Slim sticky topbar (closes #93). Sits above any in-page absolute
     * controls (MapLibre uses z-10..z-20 on /mapa). position:sticky (not
     * fixed) so the page below — including the /mapa MapLibre canvas —
     * still claims the full viewport below the bar. backdrop-blur +
     * translucent bg let map/forecast content show through subtly.
     */}
    <nav
      aria-label="Principal"
      class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/60 dark:border-gray-800 dark:bg-gray-900/80 dark:supports-[backdrop-filter]:bg-gray-900/60"
      style="padding-top:env(safe-area-inset-top)"
    >
      <div class="mx-auto flex h-12 max-w-6xl items-center justify-between gap-3 px-3 sm:h-14 sm:px-4">
        <a
          href={base}
          class="flex items-center gap-2 text-sm font-semibold text-gray-900 hover:text-blue-600 dark:text-gray-100 dark:hover:text-blue-400"
        >
          <span aria-hidden="true" class="text-base leading-none">🇲🇽</span>
          <span>Clima México</span>
        </a>
        <div class="flex items-center gap-1 sm:gap-2">
          <a
            href={base}
            class="rounded-md px-2 py-1 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
            data-i18n-en="Home"
            >Inicio</a
          >
          <a
            href={`${base}mapa`}
            class="rounded-md px-2 py-1 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
            data-i18n-en="Map"
            >Mapa</a
          >
          {/* Catálogo dropdown — story 4.1. Native <details>/<summary>
              gives us keyboard + screen-reader semantics for free
              (Enter/Space toggles, Escape closes when focused).
              Closes on outside-click via a small script below.
              Hidden below sm: on mobile the nav row is tight and
              catalog discovery happens via the homepage. */}
          <details id="catalog-dropdown" class="relative hidden sm:block">
            <summary
              class="flex cursor-pointer list-none items-center gap-1 rounded-md px-2 py-1 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
              aria-label="Abrir catálogo"
            >
              <span data-i18n-en="Catalog">Catálogo</span>
              <span aria-hidden="true" class="text-xs">▾</span>
            </summary>
            <div
              role="menu"
              class="absolute right-0 z-50 mt-1 min-w-[180px] rounded-lg border border-gray-200 bg-white py-1 text-sm shadow-lg dark:border-gray-700 dark:bg-gray-900"
            >
              <a
                role="menuitem"
                href={`${base}clima/`}
                class="block px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
                data-i18n-en="Cities"
                >Ciudades</a
              >
              <a
                role="menuitem"
                href={`${base}playa/`}
                class="block px-3 py-2 text-gray-700 hover:bg-cyan-50 hover:text-cyan-700 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-cyan-400"
                ><span aria-hidden="true">🌊</span>
                <span data-i18n-en="Beaches">Playas</span></a
              >
              <a
                role="menuitem"
                href={`${base}estado/`}
                class="block px-3 py-2 text-gray-700 hover:bg-red-50 hover:text-red-700 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-red-400"
                data-i18n-en="States"
                >Estados</a
              >
              <a
                role="menuitem"
                href={`${base}volcan/`}
                class="block px-3 py-2 text-gray-700 hover:bg-orange-50 hover:text-orange-700 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-orange-400"
                ><span aria-hidden="true">🌋</span>
                <span data-i18n-en="Volcanoes">Volcanes</span></a
              >
            </div>
          </details>
          <a
            href={`${base}pregunta`}
            class="hidden sm:inline-block rounded-md px-2 py-1 text-sm text-gray-700 hover:bg-gray-100 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-blue-400"
            data-i18n-en="Ask"
            >Pregunta</a
          >
          <LanguageToggle />
          <ThemeToggle lang={lang} />
        </div>
      </div>
    </nav>
    <script is:inline>
      // Catálogo dropdown — close on outside-click + Escape.
      (function () {
        var dd = document.getElementById('catalog-dropdown');
        if (!dd) return;
        document.addEventListener('click', function (e) {
          if (!dd.contains(e.target)) dd.removeAttribute('open');
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && dd.hasAttribute('open')) {
            dd.removeAttribute('open');
            var s = dd.querySelector('summary');
            if (s) s.focus();
          }
        });
      })();
    </script>
    <slot />
    <FeedbackFAB lang={lang} />
    <PwaInstall />
    {
      /*
       * Opt-in error monitoring. This block renders NOTHING unless
       * PUBLIC_SENTRY_DSN is provided at build time, so there is zero runtime
       * behavior and no network activity by default. When a DSN is set, the
       * Sentry browser CDN bundle is lazy-loaded and initialized.
       */
    }
    {
      sentryDsn && (
        <Fragment>
          <script
            is:inline
            src="https://browser.sentry-cdn.com/8.40.0/bundle.min.js"
            crossorigin="anonymous"
          />
          <script is:inline define:vars={{ sentryDsn }}>
            window.addEventListener('load', function () {
              if (window.Sentry) {
                window.Sentry.init({ dsn: sentryDsn });
              }
            });
          </script>
        </Fragment>
      )
    }
  </body>
</html>
