---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MX_STATES } from '../../lib/mx-states';
import { siteBase } from '../../utils/paths';
import { breadcrumbLd } from '../../lib/structured-data';

const base = siteBase();
const title = 'Clima por estado en México — Las 32 entidades federativas';
const description =
  'Pronóstico del tiempo para los 32 estados de México. ' +
  'Cada página lista la capital y las principales ciudades del estado.';
const canonical = new URL(`${base}estado/`, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Clima por estado — México',
    url: canonical,
    inLanguage: 'es-MX',
    description,
  },
  breadcrumbLd([
    { name: 'Inicio', url: homeUrl },
    { name: 'Estados', url: canonical },
  ]),
];

const states = [...MX_STATES].sort((a, b) => a.name.localeCompare(b.name, 'es'));
---

<BaseLayout title={title} description={description} lang="es" jsonLd={jsonLd}>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a href={base} class="inline-flex min-h-[44px] items-center hover:text-gray-900 dark:hover:text-gray-200 underline">
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-900 dark:text-gray-100" aria-current="page">Estados</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Clima por estado en México</h1>
        <p class="text-base text-gray-700 dark:text-gray-300">
          Pronóstico del tiempo para los 32 estados de México. Cada página agrupa la capital
          y las principales ciudades del estado, más los volcanes y playas que cubrimos.
        </p>
      </header>

      <input
        id="catalog-filter"
        type="search"
        placeholder="Filtrar por nombre o capital…"
        aria-label="Filtrar estados"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 dark:border-gray-700 dark:bg-gray-900"
      />
      <ul id="catalog-list" class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        {
          states.map((s) => (
            <li
              data-catalog-item
              data-search={`${s.name} ${s.capital}`
                .toLowerCase()
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')}
            >
              <a
                href={`${base}estado/${s.slug}/`}
                class="block rounded-md border border-gray-200 p-3 hover:border-red-500/40 dark:border-gray-800 dark:hover:border-red-500/40"
              >
                <div class="font-medium">{s.name}</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">Capital: {s.capital}</div>
              </a>
            </li>
          ))
        }
      </ul>
      <p id="catalog-empty" class="hidden text-sm text-gray-500 dark:text-gray-400">
        Sin resultados.
      </p>
      <script is:inline>
        (function () {
          var input = document.getElementById('catalog-filter');
          var empty = document.getElementById('catalog-empty');
          if (!input) return;
          function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, ''); }
          var timer;
          input.addEventListener('input', function () {
            window.clearTimeout(timer);
            timer = window.setTimeout(function () {
              var q = norm(input.value.trim());
              var items = document.querySelectorAll('[data-catalog-item]');
              var visible = 0;
              items.forEach(function (li) {
                var match = !q || (li.getAttribute('data-search') || '').indexOf(q) !== -1;
                li.classList.toggle('hidden', !match);
                if (match) visible++;
              });
              if (empty) empty.classList.toggle('hidden', visible > 0);
            }, 100);
          });
        })();
      </script>
    </div>
  </main>
</BaseLayout>
