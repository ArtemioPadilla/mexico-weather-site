---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MX_STATES, resolveStateName, type MxState } from '../../lib/mx-states';
import { TOP_CITIES, type TopCity } from '../../lib/top-cities';
import { TOP_BEACHES } from '../../lib/top-beaches';
import { siteBase } from '../../utils/paths';

/**
 * Per-state landing pages — one per entry in MX_STATES (32 federal
 * entities). Each page lists the cities in TOP_CITIES whose
 * admin matches the state, plus any beaches in TOP_BEACHES from
 * the same state. Capital city links into /clima/<capitalSlug>/ when
 * present, otherwise the URL-param /forecast/ route.
 *
 * Pure linking page — no live API call. Pulls together existing
 * static content into a state-level navigation entry point that
 * search engines can crawl.
 */
export function getStaticPaths() {
  return MX_STATES.map((state) => ({
    params: { slug: state.slug },
    props: { state },
  }));
}

const { state } = Astro.props as { state: MxState };
const base = siteBase();

const citiesInState: TopCity[] = TOP_CITIES.filter(
  (c) => resolveStateName(c.admin) === state.name,
);
const beachesInState = TOP_BEACHES.filter((b) => b.admin === state.name);

const capitalHref = state.capitalSlug
  ? `${base}clima/${state.capitalSlug}/`
  : `${base}forecast/?lat=${state.capitalLat}&lng=${state.capitalLng}` +
    `&name=${encodeURIComponent(state.capital)}` +
    `&admin=${encodeURIComponent(state.name)}` +
    `&tz=America/Mexico_City`;

const title = `Clima en ${state.name} — Pronóstico por ciudad`;
const description =
  `Pronóstico del tiempo para ${state.name}, México. ` +
  `Capital ${state.capital} y principales ciudades. ` +
  `Datos del modelo meteorológico de Open-Meteo, sin cuentas ni cookies.`;
---

<BaseLayout title={title} description={description} lang="es">
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-8">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a href={base} class="hover:text-gray-900 dark:hover:text-gray-200 underline">
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li>Estados</li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-900 dark:text-gray-100" aria-current="page">{state.name}</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          Clima en {state.name}
        </h1>
        <p class="text-base text-gray-700 dark:text-gray-300">
          Pronóstico del tiempo para {state.name}, México. La capital del estado es
          <strong>{state.capital}</strong>. A continuación las ciudades y playas
          que cubrimos en {state.name}.
        </p>
      </header>

      <section
        aria-labelledby="capital-h"
        class="rounded-lg border border-gray-200 bg-gray-50 p-5 dark:border-gray-800 dark:bg-gray-900"
      >
        <h2 id="capital-h" class="text-lg font-semibold">Capital</h2>
        <a
          href={capitalHref}
          class="mt-2 inline-flex items-center gap-1 text-blue-700 hover:underline dark:text-blue-400"
        >
          <span class="text-base font-medium">{state.capital}</span>
          <span aria-hidden="true">→</span>
        </a>
      </section>

      {
        citiesInState.length > 0 && (
          <section aria-labelledby="cities-h" class="space-y-3">
            <h2 id="cities-h" class="text-lg font-semibold">Ciudades</h2>
            <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
              {citiesInState.map((c) => (
                <li>
                  <a
                    href={`${base}clima/${c.slug}/`}
                    class="block rounded-md border border-gray-200 p-3 hover:border-blue-500/40 dark:border-gray-800 dark:hover:border-blue-500/40"
                  >
                    <div class="font-medium">{c.name}</div>
                    <div class="text-xs text-gray-600 dark:text-gray-400">
                      {c.lat.toFixed(2)}°, {c.lng.toFixed(2)}°
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        beachesInState.length > 0 && (
          <section aria-labelledby="beaches-h" class="space-y-3">
            <h2 id="beaches-h" class="text-lg font-semibold">Playas</h2>
            <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
              {beachesInState.map((b) => (
                <li>
                  <a
                    href={`${base}playa/${b.slug}/`}
                    class="block rounded-md border border-gray-200 p-3 hover:border-cyan-500/40 dark:border-gray-800 dark:hover:border-cyan-500/40"
                  >
                    <div class="font-medium">
                      <span aria-hidden="true">🌊</span> {b.name}
                    </div>
                    <div class="text-xs text-gray-600 dark:text-gray-400">
                      {b.lat.toFixed(2)}°, {b.lng.toFixed(2)}°
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <nav aria-label="Otros estados" class="border-t border-gray-200 pt-6 dark:border-gray-800">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
          Otros estados
        </h2>
        <ul class="flex flex-wrap gap-2">
          {
            MX_STATES.filter((s) => s.slug !== state.slug).map((s) => (
              <li>
                <a
                  href={`${base}estado/${s.slug}/`}
                  class="inline-block rounded-md border border-gray-200 px-3 py-1 text-sm text-blue-700 hover:bg-blue-50 dark:border-gray-700 dark:text-blue-400 dark:hover:bg-gray-900"
                >
                  {s.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </main>
</BaseLayout>
