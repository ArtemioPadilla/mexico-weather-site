---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOP_CITIES } from '../../lib/top-cities';
import { siteBase } from '../../utils/paths';
import { breadcrumbLd } from '../../lib/structured-data';

const base = siteBase();
const title = 'Clima por ciudad en México — Pronóstico de las principales ciudades';
const titleEn = 'Weather by city in Mexico — Forecast for major cities';
const description =
  'Pronóstico del tiempo para las principales ciudades de México: ' +
  'CDMX, Guadalajara, Monterrey, Puebla, Tijuana y más. ' +
  'Datos del modelo meteorológico de Open-Meteo, sin cuentas ni cookies.';
const descriptionEn =
  'Weather forecast for major Mexican cities: ' +
  'CDMX, Guadalajara, Monterrey, Puebla, Tijuana and more. ' +
  'Open-Meteo model data — no accounts, no cookies.';
const canonical = new URL(`${base}clima/`, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Clima por ciudad — México',
    url: canonical,
    inLanguage: 'es-MX',
    description,
  },
  breadcrumbLd([
    { name: 'Inicio', url: homeUrl },
    { name: 'Clima por ciudad', url: canonical },
  ]),
];

// Population-sort so the largest metros are visually first.
const cities = [...TOP_CITIES].sort((a, b) => a.name.localeCompare(b.name, 'es'));
---

<BaseLayout
  title={title}
  description={description}
  titleEn={titleEn}
  descriptionEn={descriptionEn}
  lang="es"
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a
              href={base}
              class="inline-flex min-h-[44px] items-center hover:text-gray-900 dark:hover:text-gray-200 underline"
              data-i18n-en="Home"
            >
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li
            class="text-gray-900 dark:text-gray-100"
            aria-current="page"
            data-i18n-en="Weather by city"
          >Clima por ciudad</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          data-i18n-en="Weather by city in Mexico"
        >Clima por ciudad en México</h1>
        <p
          class="text-base text-gray-700 dark:text-gray-300"
          data-i18n-en={`Weather forecast for the ${cities.length} major Mexican cities. Open-Meteo model data. Covers all 32 federal entities with their capital or main city.`}
        >
          Pronóstico del tiempo para las {cities.length} principales ciudades de México.
          Datos del modelo meteorológico de Open-Meteo. Cubre todas las 32 entidades
          federativas con su capital o ciudad principal.
        </p>
      </header>

      <input
        id="catalog-filter"
        type="search"
        placeholder="Filtrar por nombre o estado…"
        data-i18n-en-placeholder="Filter by name or state…"
        aria-label="Filtrar ciudades"
        data-i18n-en-aria-label="Filter cities"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900"
      />
      <ul id="catalog-list" class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        {
          cities.map((c) => (
            <li
              data-catalog-item
              data-search={`${c.name} ${c.admin}`
                .toLowerCase()
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')}
            >
              <a
                href={`${base}clima/${c.slug}/`}
                class="block rounded-md border border-gray-200 p-3 hover:border-blue-500/40 dark:border-gray-800 dark:hover:border-blue-500/40"
              >
                <div class="font-medium">{c.name}</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">{c.admin}</div>
              </a>
            </li>
          ))
        }
      </ul>
      <p
        id="catalog-empty"
        class="hidden text-sm text-gray-500 dark:text-gray-400"
        data-i18n-en="No results."
      >
        Sin resultados.
      </p>
      <script is:inline>
        (function () {
          var input = document.getElementById('catalog-filter');
          var empty = document.getElementById('catalog-empty');
          if (!input) return;
          function norm(s) {
            return s
              .toLowerCase()
              .normalize('NFD')
              .replace(/[̀-ͯ]/g, '');
          }
          var timer;
          input.addEventListener('input', function () {
            window.clearTimeout(timer);
            timer = window.setTimeout(function () {
              var q = norm(input.value.trim());
              var items = document.querySelectorAll('[data-catalog-item]');
              var visible = 0;
              items.forEach(function (li) {
                var hay = li.getAttribute('data-search') || '';
                var match = !q || hay.indexOf(q) !== -1;
                li.classList.toggle('hidden', !match);
                if (match) visible++;
              });
              if (empty) empty.classList.toggle('hidden', visible > 0);
            }, 100);
          });
        })();
      </script>
    </div>
  </main>
</BaseLayout>
