---
import AqiPanel from '../../components/AqiPanel.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClimateAnomalyBadge from '../../components/ClimateAnomalyBadge.astro';
import ShareButton from '../../components/ShareButton.astro';
import SmnAvisos from '../../components/SmnAvisos.astro';
import { TOP_CITIES, type TopCity } from '../../lib/top-cities';
import { findStateByAdmin } from '../../lib/mx-states';
import { siteBase } from '../../utils/paths';
import { breadcrumbLd, cityLd } from '../../lib/structured-data';

/**
 * Statically generated per-city landing page (one per slug in
 * TOP_CITIES). Renders SEO content server-side — city name in title,
 * H1, meta description — then hydrates "now" + 3-day preview from
 * Open-Meteo at page load. Big CTA points to the full interactive
 * /forecast/?lat=&lng=&… so the page is a teaser, not a
 * reimplementation.
 *
 * Server-rendered HTML matters because the interactive /forecast/
 * page is empty before JS runs, which is bad SEO. These per-city
 * landings give Google something to index for each metro.
 */
export function getStaticPaths() {
  return TOP_CITIES.map((city) => ({
    params: { slug: city.slug },
    props: {
      city,
      otherCities: TOP_CITIES.filter((c) => c.slug !== city.slug).slice(0, 10),
    },
  }));
}

const { city, otherCities } = Astro.props as {
  city: TopCity;
  otherCities: TopCity[];
};
const base = siteBase();
const state = findStateByAdmin(city.admin);
const forecastHref =
  `${base}forecast/?lat=${city.lat}&lng=${city.lng}` +
  `&name=${encodeURIComponent(city.name)}` +
  `&admin=${encodeURIComponent(city.admin)}` +
  `&tz=${encodeURIComponent(city.tz)}`;

const title = `Clima en ${city.name} — Pronóstico para hoy y los próximos días`;
const titleEn = `${city.name} weather — Today's forecast and next days`;
const description =
  `Pronóstico del tiempo para ${city.name}, ${city.admin}. ` +
  `Temperatura actual, lluvia, viento y los próximos 7 días. ` +
  `Datos del modelo meteorológico de Open-Meteo, sin cuentas ni cookies.`;
const descriptionEn =
  `Weather forecast for ${city.name}, ${city.admin}. ` +
  `Current temperature, rain, wind, and the next 7 days. ` +
  `Open-Meteo model data — no accounts, no cookies.`;

const canonical = new URL(`${base}clima/${city.slug}/`, Astro.site).href;
const ogImage = new URL(`${base}og/clima/${city.slug}.png`, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;
const jsonLd = [
  cityLd({
    name: city.name,
    admin: city.admin,
    lat: city.lat,
    lng: city.lng,
    canonical,
  }),
  breadcrumbLd([
    { name: 'Inicio', url: homeUrl },
    { name: 'Clima por ciudad', url: new URL(`${base}clima/`, Astro.site).href },
    { name: city.name, url: canonical },
  ]),
];
---

<BaseLayout
  title={title}
  description={description}
  titleEn={titleEn}
  descriptionEn={descriptionEn}
  lang="es"
  image={ogImage}
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-8">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a
              href={base}
              class="inline-flex min-h-[44px] items-center hover:text-gray-900 dark:hover:text-gray-200 underline"
              data-i18n-en="Home"
            >
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li data-i18n-en="Weather by city">Clima por ciudad</li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-900 dark:text-gray-100" aria-current="page">{city.name}</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          data-i18n-en-html={`Weather in ${city.name}, <span class="text-gray-700 dark:text-gray-300">${city.admin}</span>`}
        >
          Clima en {city.name}, <span class="text-gray-700 dark:text-gray-300">{city.admin}</span>
        </h1>
        <p
          class="text-base text-gray-700 dark:text-gray-300"
          data-i18n-en={`Weather forecast for ${city.name}. Current temperature, rain, wind, and the next 7 days. Open-Meteo model data, free and without registration.`}
        >
          Pronóstico del tiempo para {city.name}. Temperatura actual, lluvia, viento y los próximos
          7 días. Datos del modelo meteorológico de Open-Meteo, gratis y sin registro.
        </p>
      </header>

      <SmnAvisos stateSlug={state?.slug} />

      <AqiPanel coords={{ lat: city.lat, lng: city.lng }} />

      <section
        aria-labelledby="now-h"
        class="rounded-lg border border-gray-200 bg-gray-50 p-5 dark:border-gray-800 dark:bg-gray-900"
      >
        <h2
          id="now-h"
          class="text-lg font-semibold"
          data-i18n-en={`Now in ${city.name}`}
        >Ahora en {city.name}</h2>
        <div
          id="now-loading"
          aria-hidden="true"
          class="mt-3 space-y-2 animate-pulse"
        >
          <div class="h-10 w-32 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-4 w-48 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-4 w-64 rounded bg-gray-200 dark:bg-gray-800"></div>
        </div>
        <div id="now-content" class="mt-3 hidden">
          <div class="flex items-baseline gap-2">
            <span id="now-temp" class="text-4xl font-bold tabular-nums">—</span>
            <span class="text-xl text-gray-500 dark:text-gray-400">°C</span>
            <span id="now-feels" class="ml-2 text-sm text-gray-600 dark:text-gray-400"></span>
          </div>
          <p id="now-cond" class="mt-1 text-base text-gray-800 dark:text-gray-200">—</p>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
            <span id="now-wind" data-i18n-en="Wind —">Viento —</span> ·
            <span id="now-humidity" data-i18n-en="Humidity —">Humedad —</span>
          </p>
          <ClimateAnomalyBadge coords={{ lat: city.lat, lng: city.lng }} />
        </div>
        <p
          id="now-error"
          class="mt-3 hidden text-sm text-red-600 dark:text-red-400"
          data-i18n-en-html={`We couldn't load the current weather. <a id="now-error-link" href="${forecastHref}" class="underline">Try the full forecast</a>.`}
        >
          No pudimos cargar el clima actual.
          <a id="now-error-link" href={forecastHref} class="underline">Intenta el pronóstico completo</a>.
        </p>
      </section>

      <section aria-labelledby="next-h" class="space-y-3">
        <h2 id="next-h" class="text-lg font-semibold" data-i18n-en="Next days">
          Próximos días
        </h2>
        <ul id="next-list" class="grid grid-cols-1 gap-2 sm:grid-cols-3">
          <li class="h-20 rounded-md bg-gray-100 animate-pulse dark:bg-gray-900"></li>
          <li class="h-20 rounded-md bg-gray-100 animate-pulse dark:bg-gray-900"></li>
          <li class="h-20 rounded-md bg-gray-100 animate-pulse dark:bg-gray-900"></li>
        </ul>
      </section>

      <a
        href={forecastHref}
        class="block rounded-lg bg-blue-600 px-5 py-4 text-center text-white shadow-sm hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:bg-blue-500 dark:hover:bg-blue-600"
      >
        <span
          class="font-semibold"
          data-i18n-en={`See full forecast for ${city.name}`}
        >Ver pronóstico completo de {city.name}</span>
        <span
          class="block text-sm opacity-90"
          data-i18n-en="7 days, interactive map, SMN alerts, air quality"
        >
          7 días, mapa interactivo, alertas SMN, calidad del aire
        </span>
      </a>

      <section
        aria-labelledby="meta-h"
        class="flex flex-wrap items-center justify-between gap-3 text-sm text-gray-600 dark:text-gray-400"
      >
        <div>
          <h2 id="meta-h" class="sr-only" data-i18n-en="Location details">
            Detalles de ubicación
          </h2>
          <p
            data-i18n-en-html={`Coordinates: ${city.lat.toFixed(2)}°, ${city.lng.toFixed(2)}° · Time zone: <code class="text-xs">${city.tz}</code>`}
          >
            Coordenadas: {city.lat.toFixed(2)}°, {city.lng.toFixed(2)}° · Zona horaria:
            <code class="text-xs">{city.tz}</code>
          </p>
        </div>
        <ShareButton
          label={`Compartir ${city.name}`}
          shareTitle={`Clima en ${city.name} — Clima México`}
        />
      </section>

      {
        state && (
          <section
            aria-labelledby="state-h"
            class="rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm dark:border-blue-900 dark:bg-blue-950"
          >
            <h2 id="state-h" class="sr-only" data-i18n-en="State">
              Estado
            </h2>
            <p
              class="text-gray-700 dark:text-gray-300"
              data-i18n-en-html={`<span aria-hidden="true">📍</span> See the whole state summary: <a href="${base}estado/${state.slug}/" class="font-medium text-blue-700 hover:underline dark:text-blue-400">Weather in ${state.name} →</a>`}
            >
              <span aria-hidden="true">📍</span> Ver el resumen de todo el estado:{' '}
              <a
                href={`${base}estado/${state.slug}/`}
                class="font-medium text-blue-700 hover:underline dark:text-blue-400"
              >
                Clima en {state.name} →
              </a>
            </p>
          </section>
        )
      }

      <nav aria-label="Otras ciudades" class="border-t border-gray-200 pt-6 dark:border-gray-800">
        <h2
          class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"
          data-i18n-en="Other cities"
        >
          Otras ciudades
        </h2>
        <ul class="flex flex-wrap gap-2">
          {
            otherCities.map((c) => (
              <li>
                <a
                  href={`${base}clima/${c.slug}/`}
                  class="inline-block rounded-md border border-gray-200 px-3 py-1 text-sm text-blue-700 hover:bg-blue-50 dark:border-gray-700 dark:text-blue-400 dark:hover:bg-gray-900"
                >
                  {c.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </main>

  <div
    id="city-data"
    data-lat={city.lat}
    data-lng={city.lng}
    data-tz={city.tz}
    data-name={city.name}
    data-slug={city.slug}
    data-base={base}
    class="hidden"
  ></div>

  <script>
    import { getForecast } from '../../lib/forecast';
    import { translateCondition } from '../../lib/weather';

    const dataEl = document.getElementById('city-data');
    const data = {
      lat: Number(dataEl?.dataset.lat ?? NaN),
      lng: Number(dataEl?.dataset.lng ?? NaN),
      tz: dataEl?.dataset.tz ?? 'auto',
      name: dataEl?.dataset.name ?? '',
      slug: dataEl?.dataset.slug ?? '',
      base: dataEl?.dataset.base ?? '/',
    };

    /** Slim shape emitted by scripts/build-city-forecasts.py. */
    interface SnapshotDoc {
      updated?: string;
      current?: {
        temperature?: number | null;
        feelsLike?: number | null;
        condition?: string | null;
        windKmh?: number | null;
        humidity?: number | null;
      };
      next?: Array<{
        date?: string;
        condition?: string;
        hi?: number | null;
        lo?: number | null;
      }>;
    }

    /** View model the renderer consumes. Both the static snapshot
     *  and the live fallback get normalized into this shape. */
    interface CityView {
      temperature: number | null;
      feelsLike: number | null;
      condition: string;
      windKmh: number;
      humidity: number;
      next: Array<{
        date: string;
        condition: string;
        hi: number | null;
        lo: number | null;
      }>;
    }

    async function loadStatic(): Promise<CityView | null> {
      if (!data.slug || !data.base) return null;
      try {
        const r = await fetch(`${data.base}data/city-forecast/${data.slug}.json`);
        if (!r.ok) return null;
        const doc = (await r.json()) as SnapshotDoc;
        const cur = doc.current ?? {};
        return {
          temperature: cur.temperature ?? null,
          feelsLike: cur.feelsLike ?? null,
          condition: cur.condition ?? '—',
          windKmh: Number(cur.windKmh ?? 0),
          humidity: Number(cur.humidity ?? 0),
          next: (doc.next ?? [])
            .filter((d) => typeof d?.date === 'string')
            .map((d) => ({
              date: d.date as string,
              condition: d.condition ?? '—',
              hi: d.hi ?? null,
              lo: d.lo ?? null,
            })),
        };
      } catch {
        return null;
      }
    }

    async function loadLive(): Promise<CityView | null> {
      try {
        const fc = await getForecast(
          { lat: data.lat, lng: data.lng, tz: data.tz ?? 'auto' },
          { fetch: window.fetch.bind(window) },
        );
        return {
          temperature: fc.current.temperature,
          feelsLike: fc.current.feelsLike,
          condition: fc.current.condition || '—',
          windKmh: fc.current.windSpeed,
          humidity: fc.current.humidity,
          next: fc.daily.slice(1, 4).map((d) => ({
            date: d.date,
            condition: d.condition,
            hi: d.tmax,
            lo: d.tmin,
          })),
        };
      } catch {
        return null;
      }
    }

    const loadingEl = document.getElementById('now-loading');
    const contentEl = document.getElementById('now-content');
    const errorEl = document.getElementById('now-error');
    const tempEl = document.getElementById('now-temp');
    const feelsEl = document.getElementById('now-feels');
    const condEl = document.getElementById('now-cond');
    const windEl = document.getElementById('now-wind');
    const humEl = document.getElementById('now-humidity');
    const nextList = document.getElementById('next-list');

    function fmtTemp(n: number | null): string {
      return n === null ? '—' : String(Math.round(n));
    }

    // Runtime language read — set by BaseLayout pre-paint script.
    const lang = (document.documentElement.getAttribute('data-lang') === 'en'
      ? 'en'
      : 'es') as 'es' | 'en';
    const tr = {
      es: { feels: 'Sensación', wind: 'Viento', humidity: 'Humedad' },
      en: { feels: 'Feels like', wind: 'Wind', humidity: 'Humidity' },
    }[lang];

    function dayShort(iso: string): string {
      try {
        const d = new Date(iso + 'T12:00:00');
        return d.toLocaleDateString(lang === 'en' ? 'en-US' : 'es-MX', {
          weekday: 'short',
        });
      } catch {
        return iso.slice(5);
      }
    }

    function render(v: CityView): void {
      loadingEl?.classList.add('hidden');
      contentEl?.classList.remove('hidden');
      if (tempEl) tempEl.textContent = fmtTemp(v.temperature);
      if (feelsEl)
        feelsEl.textContent =
          v.feelsLike === null ? '' : `${tr.feels} ${fmtTemp(v.feelsLike)}°`;
      if (condEl) condEl.textContent = translateCondition(v.condition || '—', lang);
      if (windEl) windEl.textContent = `${tr.wind} ${Math.round(v.windKmh)} km/h`;
      if (humEl) humEl.textContent = `${tr.humidity} ${Math.round(v.humidity)}%`;
      if (nextList && v.next.length) {
        nextList.innerHTML = v.next
          .map((d) => {
            const day = dayShort(d.date);
            const hi = fmtTemp(d.hi);
            const lo = fmtTemp(d.lo);
            const cond = translateCondition(d.condition || '', lang).replace(
              /[<>&"']/g,
              '',
            );
            return (
              `<li class="rounded-md border border-gray-200 bg-white p-3 dark:border-gray-800 dark:bg-gray-900">` +
              `<div class="text-sm font-medium capitalize">${day}</div>` +
              `<div class="mt-1 text-sm text-gray-700 dark:text-gray-300">${cond}</div>` +
              `<div class="mt-1 text-base"><span class="font-semibold">${hi}°</span> ` +
              `<span class="text-gray-500 dark:text-gray-400">/ ${lo}°</span></div>` +
              `</li>`
            );
          })
          .join('');
      }
    }

    async function run(): Promise<void> {
      if (!Number.isFinite(data.lat) || !Number.isFinite(data.lng)) {
        loadingEl?.classList.add('hidden');
        errorEl?.classList.remove('hidden');
        return;
      }
      const view = (await loadStatic()) ?? (await loadLive());
      if (!view) {
        loadingEl?.classList.add('hidden');
        errorEl?.classList.remove('hidden');
        if (nextList) nextList.innerHTML = '';
        return;
      }
      render(view);
    }

    void run();
  </script>
</BaseLayout>
