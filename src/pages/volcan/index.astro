---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MX_VOLCANOES } from '../../lib/mx-volcanoes';
import { siteBase } from '../../utils/paths';
import { breadcrumbLd } from '../../lib/structured-data';

const base = siteBase();
const title = 'Volcanes de México — Monitoreo y clima';
const description =
  'Información sobre los volcanes monitoreados de México: Popocatépetl, ' +
  'Volcán de Colima, El Chichón, Tacaná, Pico de Orizaba, Iztaccíhuatl, ' +
  'Nevado de Toluca. Datos de CENAPRED y clima de Open-Meteo.';
const canonical = new URL(`${base}volcan/`, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Volcanes de México',
    url: canonical,
    inLanguage: 'es-MX',
    description,
  },
  breadcrumbLd([
    { name: 'Inicio', url: homeUrl },
    { name: 'Volcanes', url: canonical },
  ]),
];

// Elevation-descending so Pico de Orizaba (5636 m) tops the list.
const volcanoes = [...MX_VOLCANOES].sort((a, b) => b.elevationM - a.elevationM);
---

<BaseLayout title={title} description={description} lang="es" jsonLd={jsonLd}>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a href={base} class="hover:text-gray-900 dark:hover:text-gray-200 underline">
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-900 dark:text-gray-100" aria-current="page">Volcanes</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          <span aria-hidden="true">🌋</span> Volcanes de México
        </h1>
        <p class="text-base text-gray-700 dark:text-gray-300">
          Información biográfica de los {volcanoes.length} volcanes monitoreados de México,
          con enlaces al monitoreo oficial de CENAPRED y al clima de cada zona. Ordenados
          por elevación.
        </p>
      </header>

      <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        {
          volcanoes.map((v) => (
            <li>
              <a
                href={`${base}volcan/${v.slug}/`}
                class="block rounded-md border border-gray-200 p-3 hover:border-orange-500/40 dark:border-gray-800 dark:hover:border-orange-500/40"
              >
                <div class="font-medium">{v.name}</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">
                  {v.elevationM} m · {v.admin}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</BaseLayout>
