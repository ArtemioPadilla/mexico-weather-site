---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MX_VOLCANOES } from '../../lib/mx-volcanoes';
import { siteBase } from '../../utils/paths';
import { breadcrumbLd } from '../../lib/structured-data';

const base = siteBase();
const title = 'Volcanes de México — Monitoreo y clima';
const titleEn = 'Volcanoes of Mexico — Monitoring and weather';
const description =
  'Información sobre los volcanes monitoreados de México: Popocatépetl, ' +
  'Volcán de Colima, El Chichón, Tacaná, Pico de Orizaba, Iztaccíhuatl, ' +
  'Nevado de Toluca. Datos de CENAPRED y clima de Open-Meteo.';
const descriptionEn =
  'About the monitored volcanoes of Mexico: Popocatépetl, Volcán de ' +
  'Colima, El Chichón, Tacaná, Pico de Orizaba, Iztaccíhuatl, ' +
  'Nevado de Toluca. CENAPRED data and Open-Meteo weather.';
const canonical = new URL(`${base}volcan/`, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Volcanes de México',
    url: canonical,
    inLanguage: 'es-MX',
    description,
  },
  breadcrumbLd([
    { name: 'Inicio', url: homeUrl },
    { name: 'Volcanes', url: canonical },
  ]),
];

// Elevation-descending so Pico de Orizaba (5636 m) tops the list.
const volcanoes = [...MX_VOLCANOES].sort((a, b) => b.elevationM - a.elevationM);
---

<BaseLayout
  title={title}
  description={description}
  titleEn={titleEn}
  descriptionEn={descriptionEn}
  lang="es"
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a
              href={base}
              class="inline-flex min-h-[44px] items-center hover:text-gray-900 dark:hover:text-gray-200 underline"
              data-i18n-en="Home"
            >
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-900 dark:text-gray-100" aria-current="page" data-i18n-en="Volcanoes">Volcanes</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          data-i18n-en-html={`<span aria-hidden="true">🌋</span> Volcanoes of Mexico`}
        >
          <span aria-hidden="true">🌋</span> Volcanes de México
        </h1>
        <p
          class="text-base text-gray-700 dark:text-gray-300"
          data-i18n-en={`Biographical information for the ${volcanoes.length} monitored volcanoes of Mexico, with links to official CENAPRED monitoring and weather for each zone. Sorted by elevation.`}
        >
          Información biográfica de los {volcanoes.length} volcanes monitoreados de México,
          con enlaces al monitoreo oficial de CENAPRED y al clima de cada zona. Ordenados
          por elevación.
        </p>
      </header>

      <input
        id="catalog-filter"
        type="search"
        placeholder="Filtrar por nombre o estado…"
        data-i18n-en-placeholder="Filter by name or state…"
        aria-label="Filtrar volcanes"
        data-i18n-en-aria-label="Filter volcanoes"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 dark:border-gray-700 dark:bg-gray-900"
      />
      <ul id="catalog-list" class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        {
          volcanoes.map((v) => (
            <li
              data-catalog-item
              data-search={`${v.name} ${v.admin}`
                .toLowerCase()
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')}
            >
              <a
                href={`${base}volcan/${v.slug}/`}
                class="block rounded-md border border-gray-200 p-3 hover:border-orange-500/40 dark:border-gray-800 dark:hover:border-orange-500/40"
              >
                <div class="font-medium">{v.name}</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">
                  {v.elevationM} m · {v.admin}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
      <p
        id="catalog-empty"
        class="hidden text-sm text-gray-500 dark:text-gray-400"
        data-i18n-en="No results."
      >
        Sin resultados.
      </p>
      <script is:inline>
        (function () {
          var input = document.getElementById('catalog-filter');
          var empty = document.getElementById('catalog-empty');
          if (!input) return;
          function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, ''); }
          var timer;
          input.addEventListener('input', function () {
            window.clearTimeout(timer);
            timer = window.setTimeout(function () {
              var q = norm(input.value.trim());
              var items = document.querySelectorAll('[data-catalog-item]');
              var visible = 0;
              items.forEach(function (li) {
                var match = !q || (li.getAttribute('data-search') || '').indexOf(q) !== -1;
                li.classList.toggle('hidden', !match);
                if (match) visible++;
              });
              if (empty) empty.classList.toggle('hidden', visible > 0);
            }, 100);
          });
        })();
      </script>
    </div>
  </main>
</BaseLayout>
