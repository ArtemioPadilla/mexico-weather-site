---
import AqiPanel from '../components/AqiPanel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import MarinePanel from '../components/MarinePanel.astro';
import SmnAvisos from '../components/SmnAvisos.astro';
import { ui } from '../i18n/ui';

// keep in sync with the other lang declaration in this file
const lang = 'es' as const;
const t = ui[lang];
---

<BaseLayout
  title="Pronóstico — Clima México 🇲🇽"
  description="Pronóstico detallado por ubicación"
  lang={lang}
>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <div
        id="fc-empty"
        class="hidden rounded-lg border border-gray-200 bg-white p-6 text-center space-y-4 dark:border-gray-800 dark:bg-gray-900"
      >
        <p class="text-gray-700 dark:text-gray-300">{t.pick_location}</p>
        <a
          href={import.meta.env.BASE_URL}
          class="inline-block text-sm text-blue-600 hover:underline dark:text-blue-400"
          >← {t.back_home}</a
        >
      </div>

      <p id="fc-status" aria-live="polite" class="sr-only">{t.loading}</p>

      <div id="fc-skeleton" aria-hidden="true" class="space-y-6 animate-pulse">
        {/* Hero: title bar, subline, big temp, condition, sunrise/sunset */}
        <div class="space-y-2">
          <div class="h-7 w-2/3 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-3 w-1/3 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="flex items-end gap-3 pt-2">
            <div class="h-14 w-28 rounded bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-4 w-20 rounded bg-gray-200 dark:bg-gray-800 mb-1"></div>
          </div>
          <div class="h-5 w-1/2 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-3 w-2/3 rounded bg-gray-200 dark:bg-gray-800"></div>
          {/* Issue #107 — reserve map height during skeleton too */}
          <div class="fc-map-wrap mt-3"></div>
        </div>

        {/* Hourly row */}
        <div class="space-y-2">
          <div class="h-5 w-2/5 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="flex gap-2 overflow-hidden pb-2 pr-6 [mask-image:linear-gradient(to_right,black_90%,transparent)] [-webkit-mask-image:linear-gradient(to_right,black_90%,transparent)]">
            <div class="h-24 w-[62px] flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-24 w-[62px] flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-24 w-[62px] flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-24 w-[62px] flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-24 w-[62px] flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-24 w-[62px] flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="h-9 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
        </div>

        {/* 7-day rows */}
        <div class="space-y-1">
          <div class="h-5 w-1/4 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="h-7 w-full rounded bg-gray-200 dark:bg-gray-800"></div>
        </div>

        {/* Detail panels */}
        <div class="space-y-2">
          <div class="h-5 w-1/4 rounded bg-gray-200 dark:bg-gray-800"></div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div class="h-20 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-20 rounded-md bg-gray-200 dark:bg-gray-800"></div>
            <div class="h-20 rounded-md bg-gray-200 dark:bg-gray-800"></div>
          </div>
        </div>
      </div>

      {/* Coords come from URL params (?lat=&lng=); SmnAvisos reads
          them at runtime and resolves the state via the static
          polygon lookup. */}
      <SmnAvisos />
      <AqiPanel />
      <MarinePanel />

      <section id="fc-root" class="hidden space-y-6" aria-live="polite"></section>
    </div>
  </main>

  <style is:global>
    /* Issue #107 — reserve map height BEFORE MapLibre loads to prevent CLS.
       Bumped to 320 px (sm: 360 px) so the embedded INTERACTIVE map (full
       MapLibre instance with pan/zoom + popup; previously a 160-px static
       click-through) has room to breathe. */
    .fc-map-wrap {
      position: relative;
      height: 320px;
      width: 100%;
      overflow: hidden;
      border-radius: 0.5rem;
      background: rgb(229 231 235); /* gray-200 */
      display: block;
    }
    .dark .fc-map-wrap {
      background: rgb(31 41 55); /* gray-800 */
    }
    @media (min-width: 640px) {
      .fc-map-wrap { height: 360px; }
    }
    /* Issue #109 — axis tick marks + today marker for 7-day temperature bars. */
    .fc-axis-track {
      position: relative;
      height: 14px;
    }
    .fc-axis-tick {
      position: absolute;
      top: 6px;
      width: 1px;
      height: 8px;
      background: rgb(156 163 175); /* gray-400 */
    }
    .dark .fc-axis-tick {
      background: rgb(75 85 99); /* gray-600 */
    }
    .fc-axis-mid {
      position: absolute;
      top: 0;
      transform: translateX(-50%);
      font-size: 11px;
      color: rgb(107 114 128); /* gray-500 */
    }
    .fc-today-marker {
      position: absolute;
      top: -2px;
      width: 2px;
      height: calc(100% + 4px);
      background: rgb(220 38 38); /* red-600 */
      border-radius: 1px;
      z-index: 2;
      pointer-events: none;
    }
    .dark .fc-today-marker {
      background: rgb(248 113 113); /* red-400 */
    }
  </style>

  <script>
    import {
      getClimateAnomaly,
      getForecast,
      getModelDisagreement,
      uvLabel,
      windDir,
    } from '../lib/forecast';
    import { has, toggle } from '../lib/favorites';
    import {
      add as addAlert,
      evaluate as evaluateAlerts,
      forLocation as alertsForLocation,
      remove as removeAlert,
      type AlertMetric,
      type AlertRule,
    } from '../lib/alerts';
    import { ui } from '../i18n/ui';
    import { initInteractiveMap } from '../lib/interactive-map';

    // keep in sync with the other lang declaration in this file
    const lang: 'es' | 'en' = 'es';
    const t = ui[lang];
    const dateLocale = lang === 'es' ? 'es-MX' : 'en-US';

    const statusEl = document.getElementById('fc-status');
    const rootEl = document.getElementById('fc-root');
    const emptyEl = document.getElementById('fc-empty');
    const skeletonEl = document.getElementById('fc-skeleton');

    function hideSkeleton(): void {
      skeletonEl?.classList.add('hidden');
    }

    function showEmpty(): void {
      statusEl?.classList.add('hidden');
      hideSkeleton();
      emptyEl?.classList.remove('hidden');
    }

    // --- helpers --------------------------------------------------------
    function esc(s: string): string {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function fmt(n: number | null): string {
      return n === null ? '—' : String(Math.round(n));
    }

    function hourLabel(iso: string, idx: number): string {
      return idx === 0 ? t.current : iso.slice(11, 13) + 'h';
    }

    function dayLabel(iso: string, idx: number): string {
      if (idx === 0) return t.today;
      if (!iso) return '—';
      const d = new Date(iso + 'T12:00:00');
      if (Number.isNaN(d.getTime())) return '—';
      return d.toLocaleDateString(dateLocale, { weekday: 'long' });
    }

    function timeOnly(s: string | null): string {
      return s ? s.slice(11) : '—';
    }

    // Pull the trailing emoji from a WMO condition string ("Lluvia 🌧️").
    function emoji(condition: string): string {
      const parts = condition.trim().split(/\s+/);
      const last = parts[parts.length - 1];
      return last && /\p{Emoji}/u.test(last) ? last : '·';
    }

    // Card layout constants for the hourly row — kept in lockstep with the
    // card markup below so the sparkline (#108) lines up x-for-x with the
    // cards above it. min-w-[62px] cards + Tailwind gap-2 (8px).
    const CARD_W = 62;
    const CARD_GAP = 8;

    function sparkline(temps: number[]): string {
      // Issue #108 — render the SVG at the SAME pixel width as the cards row
      // so card i and sparkline x_i line up. The SVG sits INSIDE the same
      // overflow-x:auto container as the cards (see hourlyHtml below).
      const pts = temps.filter((n) => n !== null && Number.isFinite(n));
      if (pts.length < 2) return '';
      const n = pts.length;
      const min = Math.min(...pts);
      const max = Math.max(...pts);
      const span = max - min || 1;
      // x positions = card centers. card_i center = i * (CARD_W + CARD_GAP) + CARD_W/2
      const totalW = n * CARD_W + (n - 1) * CARD_GAP;
      const h = 36;
      const coords = pts
        .map((v, i) => {
          const x = i * (CARD_W + CARD_GAP) + CARD_W / 2;
          const y = h - 2 - ((v - min) / span) * (h - 4);
          return `${x.toFixed(1)},${y.toFixed(1)}`;
        })
        .join(' ');
      return `<svg viewBox="0 0 ${totalW} ${h}" width="${totalW}" height="${h}" class="h-9 mt-1 block flex-shrink-0" preserveAspectRatio="none" aria-hidden="true" style="min-width:${totalW}px"><polyline fill="none" stroke="#60a5fa" stroke-width="2" points="${coords}" /></svg>`;
    }

    // Issue #99 — temperature → color along the same blue→yellow→orange
    // gradient used by the 7-day bars. Returns a CSS color string.
    // Stops: 0.0 #60a5fa (blue), 0.5 #fbbf24 (yellow), 1.0 #f97316 (orange).
    function tempTint(
      temp: number | null,
      min: number,
      max: number,
    ): string {
      if (temp === null || !Number.isFinite(temp)) return '#9ca3af'; // gray-400 fallback
      const span = max - min || 1;
      const t = Math.min(1, Math.max(0, (temp - min) / span));
      const stops = [
        { p: 0.0, r: 0x60, g: 0xa5, b: 0xfa },
        { p: 0.5, r: 0xfb, g: 0xbf, b: 0x24 },
        { p: 1.0, r: 0xf9, g: 0x73, b: 0x16 },
      ];
      let a = stops[0];
      let b = stops[stops.length - 1];
      for (let i = 0; i < stops.length - 1; i++) {
        if (t >= stops[i].p && t <= stops[i + 1].p) {
          a = stops[i];
          b = stops[i + 1];
          break;
        }
      }
      const lt = (t - a.p) / (b.p - a.p || 1);
      const r = Math.round(a.r + (b.r - a.r) * lt);
      const g = Math.round(a.g + (b.g - a.g) * lt);
      const bl = Math.round(a.b + (b.b - a.b) * lt);
      return `rgb(${r},${g},${bl})`;
    }

    interface RenderLoc {
      lat: number;
      lng: number;
      tz: string;
      name: string;
      admin?: string;
    }

    async function render(loc: RenderLoc): Promise<void> {
      try {
        const fc = await getForecast(
          { lat: loc.lat, lng: loc.lng, tz: loc.tz },
          {
            fetch: window.fetch.bind(window),
            sleep: (ms: number) =>
              new Promise<void>((r) => setTimeout(r, ms)),
          },
        );

        const { current, hourly, daily } = fc;
        const safeName = (loc.name || '').replace(/[\x00-\x1f\x7f]/g, '').trim().slice(0, 100);
        const title = safeName || `${loc.lat}, ${loc.lng}`;
        document.title = title + ' — Clima México 🇲🇽';

        const d0 = daily[0];

        // Subheading: prefer the state/admin1 (escaped) when present; fall
        // back to raw coordinates otherwise.
        const safeAdmin = (loc.admin || '')
          .replace(/[\x00-\x1f\x7f]/g, '')
          .trim()
          .slice(0, 100);
        const subLine = safeAdmin
          ? esc(safeAdmin)
          : esc(loc.lat + ', ' + loc.lng);

        const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
        const mapHref = `${baseUrl}/mapa/#view=${loc.lat},${loc.lng},9z`;

        const currentHtml = `
          <header class="space-y-1">
            <div class="flex items-center flex-wrap gap-2">
              <h1 class="text-2xl font-bold">${esc(title)}</h1>
              <button type="button" id="fc-fav" class="inline-flex items-center justify-center gap-1 min-w-[44px] min-h-[44px] px-2 text-2xl leading-none text-gray-400 hover:text-amber-400 dark:text-gray-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 rounded ml-1" aria-pressed="false" aria-label="Agregar a favoritos" title="Agregar a favoritos">
                <span id="fc-fav-icon" aria-hidden="true">☆</span>
                <span id="fc-fav-saved" class="hidden text-xs font-medium text-amber-500">Guardado</span>
              </button>
              <button type="button" id="fc-alert" class="inline-flex items-center justify-center gap-1 min-w-[44px] min-h-[44px] px-2 text-xl leading-none text-gray-400 hover:text-blue-500 dark:text-gray-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded" aria-label="Crear alerta personal" title="Crear alerta personal">
                <span id="fc-alert-icon" aria-hidden="true">🔔</span>
              </button>
              <button type="button" id="fc-share" class="inline-flex items-center justify-center min-w-[44px] min-h-[44px] px-3 text-sm rounded border border-gray-300 text-gray-700 hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" aria-label="Compartir" title="Compartir">Compartir</button>
              <span id="fc-share-toast" aria-live="polite" class="hidden text-xs text-green-600 dark:text-green-400">URL copiada</span>
            </div>
            <p class="text-xs text-gray-600 dark:text-gray-500">${subLine}</p>
            <div class="flex items-end gap-3 pt-2">
              <span class="text-6xl font-bold">${fmt(current.temperature)}°</span>
              <span class="text-sm text-gray-600 dark:text-gray-400 pb-2">${esc(t.feels_like)} ${fmt(current.feelsLike)}°</span>
            </div>
            <p class="text-lg text-gray-800 dark:text-gray-200">${esc(current.condition)}</p>
            <p class="text-xs text-gray-600 dark:text-gray-500">${esc(t.sunrise)} ${esc(timeOnly(d0 ? d0.sunrise : null))} · ${esc(t.sunset)} ${esc(timeOnly(d0 ? d0.sunset : null))}</p>
            <p id="fc-updated" class="text-xs text-gray-500 dark:text-gray-500"></p>
            <p id="fc-models" class="hidden text-xs text-gray-600 dark:text-gray-400 pt-1" aria-live="polite"></p>
            <p id="fc-anomaly" class="hidden mt-2" aria-live="polite"></p>
            <div id="fc-alert-banner" class="hidden mt-2 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-900 dark:border-amber-700 dark:bg-amber-950/40 dark:text-amber-200" aria-live="polite"></div>
            <div id="fc-alert-panel" class="hidden mt-2 rounded-md border border-blue-200 bg-blue-50/70 px-3 py-2 text-sm text-blue-900 dark:border-blue-800 dark:bg-blue-950/30 dark:text-blue-200">
              <div class="font-semibold mb-1">Crear alerta personal</div>
              <div class="flex flex-wrap items-center gap-2">
                <select id="fc-alert-metric" class="rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-700 dark:bg-gray-900">
                  <option value="rain">Lluvia (mm/h)</option>
                  <option value="temp_hi">Temp. máx. (°C)</option>
                  <option value="temp_lo">Temp. mín. (°C)</option>
                  <option value="wind">Viento (km/h)</option>
                </select>
                <select id="fc-alert-op" class="rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-700 dark:bg-gray-900">
                  <option value=">">supera</option>
                  <option value="<">cae bajo</option>
                </select>
                <input id="fc-alert-thr" type="number" inputmode="decimal" step="0.1" value="1" class="w-20 rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-700 dark:bg-gray-900" aria-label="Umbral" />
                <button type="button" id="fc-alert-save" class="rounded bg-blue-600 px-2 py-1 text-xs font-semibold text-white hover:bg-blue-500">Guardar</button>
              </div>
              <ul id="fc-alert-list" class="mt-2 space-y-1 text-xs"></ul>
              <p class="mt-1 text-[11px] text-blue-700/70 dark:text-blue-300/70">Las alertas se guardan solo en tu navegador. Se evalúan al cargar esta página contra el pronóstico de 24 h.</p>
            </div>
            <div class="fc-map-wrap mt-3" aria-label="Mapa interactivo">
              <div id="fc-map" class="h-full w-full"></div>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">
              <a id="fc-map-link" href="${esc(mapHref)}" class="text-blue-600 hover:underline dark:text-blue-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded">Abrir mapa a pantalla completa →</a>
            </p>
          </header>`;

        // Issue #99 — compute 48-h min/max for the temperature tint bar at the
        // top of each hourly card. Filter out nulls so the range is real.
        const hTemps = hourly
          .map((hw) => hw.temperature)
          .filter((n): n is number => n !== null && Number.isFinite(n));
        const hMin = hTemps.length ? Math.min(...hTemps) : 0;
        const hMax = hTemps.length ? Math.max(...hTemps) : 1;

        // precip/wind/cloud/humidity/uv are non-nullable (num()->0 in the SDK); nullable fields use fmt().
        const hourCells = hourly
          .map((hw, i) => {
            const label = esc(hourLabel(hw.time, i));
            const tint = tempTint(hw.temperature, hMin, hMax);
            return `<div class="relative min-w-[62px] flex-shrink-0 rounded-md bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 p-2 text-center text-xs space-y-1 overflow-hidden">
              <i aria-hidden="true" style="position:absolute;top:0;left:0;right:0;height:2px;background:${tint}"></i>
              <div class="text-gray-600 dark:text-gray-400">${label}</div>
              <div class="text-base">${esc(emoji(hw.condition))}</div>
              <div class="font-semibold">${fmt(hw.temperature)}°</div>
              <div class="text-blue-600 dark:text-blue-400">${Math.round(hw.precipProbability)}%</div>
              <div class="text-gray-600 dark:text-gray-500">${Math.round(hw.windSpeed)} km/h</div>
            </div>`;
          })
          .join('');

        // Issue #108 — single scroll container holds a vertical stack with
        // the cards row + the sparkline; sparkline width = cards width, so
        // hour N on a card aligns with x position N on the sparkline.
        const sparklineHtml = sparkline(
          hourly
            .map((hw) => hw.temperature)
            .filter((n): n is number => n !== null),
        );
        const hourlyHtml = `
          <section class="space-y-2">
            <h2 class="text-lg font-semibold">${esc(t.hourly_48h)}</h2>
            <div tabindex="0" role="group" aria-label="${esc(t.hourly_48h)}" class="overflow-x-auto pb-2 pr-6 [mask-image:linear-gradient(to_right,black_90%,transparent)] [-webkit-mask-image:linear-gradient(to_right,black_90%,transparent)]">
              <div class="flex flex-col">
                <div class="flex gap-2">
                  ${hourCells}
                </div>
                ${sparklineHtml}
              </div>
            </div>
          </section>`;

        // 7-day temperature range bar: normalize each day's tmin–tmax
        // against the week's overall min/max so the fill spans the row.
        const dMins = daily
          .map((d) => d.tmin)
          .filter((v): v is number => v !== null);
        const dMaxs = daily
          .map((d) => d.tmax)
          .filter((v): v is number => v !== null);
        const weekMin = dMins.length ? Math.min(...dMins) : 0;
        const weekMax = dMaxs.length ? Math.max(...dMaxs) : 1;
        const span = weekMax - weekMin || 1;

        function barFill(tmin: number | null, tmax: number | null): string {
          if (tmin === null || tmax === null) return '';
          const lo = Math.min(100, Math.max(0, ((tmin - weekMin) / span) * 100));
          const hi = Math.min(100, Math.max(0, ((tmax - weekMin) / span) * 100));
          const left = Math.min(lo, hi);
          const width = Math.max(1, Math.abs(hi - lo)); // ≥1% so a valid same-temp/glitch day still shows a sliver
          return `<i style="position:absolute;left:${left.toFixed(1)}%;width:${width.toFixed(1)}%;height:100%;border-radius:9999px;background:linear-gradient(90deg,#60a5fa,#fbbf24,#f97316)"></i>`;
        }

        // Issue #109 — today marker: vertical line at the current
        // temperature's position within the week's min/max range, drawn only
        // on the "Hoy" row.
        function todayMarker(idx: number): string {
          if (idx !== 0) return '';
          const cur = current.temperature;
          if (cur === null || !Number.isFinite(cur)) return '';
          const pct = Math.min(100, Math.max(0, ((cur - weekMin) / span) * 100));
          const label = `Temperatura actual: ${Math.round(cur)}°`;
          return `<span class="fc-today-marker" role="img" aria-label="${esc(label)}" title="${esc(label)}" style="left:${pct.toFixed(1)}%"></span>`;
        }

        // precip/wind/cloud/humidity/uv are non-nullable (num()->0 in the SDK); nullable fields use fmt().
        const dayRows = daily
          .map((dw, i) => {
            return `<div class="grid grid-cols-[5rem_1.5rem_1fr_3rem_5rem] items-center gap-2 py-1.5 border-b border-gray-200 dark:border-gray-800 text-sm">
              <span class="capitalize text-gray-700 dark:text-gray-300">${esc(dayLabel(dw.date, i))}</span>
              <span class="text-center">${esc(emoji(dw.condition))}</span>
              <span class="relative h-1.5 rounded-full bg-gray-200 dark:bg-gray-800 overflow-visible">${barFill(dw.tmin, dw.tmax)}${todayMarker(i)}</span>
              <span class="text-blue-600 dark:text-blue-400 text-right">💧${Math.round(dw.precipProbabilityMax)}%</span>
              <span class="text-right text-gray-700 dark:text-gray-300">${fmt(dw.tmin)}° / ${fmt(dw.tmax)}°</span>
            </div>`;
          })
          .join('');

        // Issue #109 — axis row above the day rows, aligned with the bar
        // column. Same grid template so the axis sits over the bar exactly.
        const midWeek = (weekMin + weekMax) / 2;
        const axisHtml = `
          <div class="grid grid-cols-[5rem_1.5rem_1fr_3rem_5rem] items-center gap-2 pb-1 text-[11px] text-gray-500 dark:text-gray-500" aria-hidden="true">
            <span></span>
            <span></span>
            <div class="fc-axis-track">
              <span class="fc-axis-tick" style="left:25%"></span>
              <span class="fc-axis-tick" style="left:50%"></span>
              <span class="fc-axis-tick" style="left:75%"></span>
              <span class="fc-axis-mid" style="left:0%;transform:translateX(0)">${fmt(weekMin)}°</span>
              <span class="fc-axis-mid" style="left:50%">${fmt(midWeek)}°</span>
              <span class="fc-axis-mid" style="left:100%;transform:translateX(-100%)">${fmt(weekMax)}°</span>
            </div>
            <span></span>
            <span></span>
          </div>`;

        const sevenHtml = `
          <section class="space-y-1">
            <h2 class="text-lg font-semibold">${esc(t.seven_days)}</h2>
            ${axisHtml}
            ${dayRows}
          </section>`;

        const wd = windDir(current.windDir);
        const uv = uvLabel(current.uvIndex);

        const detailHtml = `
          <section class="space-y-2">
            <h2 class="text-lg font-semibold">${esc(t.detail)}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div class="rounded-md bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 p-3 space-y-1">
                <div class="text-xs text-gray-600 dark:text-gray-500"><span aria-hidden="true">🧭</span> <span>${esc(t.wind)}</span></div>
                <div class="text-lg font-semibold">${Math.round(current.windSpeed)} km/h</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">${esc(wd.label)} · ${esc(t.gusts)} ${Math.round(current.windGusts)} km/h</div>
              </div>
              <div class="rounded-md bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 p-3 space-y-1">
                <div class="text-xs text-gray-600 dark:text-gray-500"><span aria-hidden="true">☀️</span> <span>${esc(t.uv_index)}</span></div>
                <div class="text-lg font-semibold">${esc(String(uv.value))}</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">${esc(uv.level)}</div>
              </div>
              <div class="rounded-md bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 p-3 space-y-1">
                <div class="text-xs text-gray-600 dark:text-gray-500"><span aria-hidden="true">☁️</span> <span>${esc(t.sky_air)}</span></div>
                <div class="text-lg font-semibold">${Math.round(current.cloudCover)}%</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">${esc(t.humidity)} ${Math.round(current.humidity)}% · ${esc(t.pressure)} ${fmt(current.pressure)} hPa · ${esc(t.visibility)} ${esc(String(current.visibilityKm))} km</div>
              </div>
            </div>
          </section>`;

        const contextHtml = `
          <div class="rounded-md border border-yellow-600/60 bg-yellow-600/10 p-3 text-sm text-yellow-900 dark:text-yellow-100">
            ⚠️ Contexto SMN/CONAGUA — avisos vigentes:
            <a href="${esc(baseUrl)}/rss.xml" target="_blank" rel="noopener noreferrer" class="underline">rss.xml</a>
          </div>
          <footer class="border-t border-gray-200 dark:border-gray-800 mt-4 pt-3 text-center text-[11px] text-gray-500 dark:text-gray-600">Datos: Open-Meteo (ECMWF/DWD/GFS) · Alertas: SMN / CONAGUA · Sin cookies · Sin rastreo · <a href="https://artemiop.com/" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors dark:hover:text-gray-300">Artemio Padilla</a></footer>`;

        if (rootEl) {
          rootEl.innerHTML =
            currentHtml +
            hourlyHtml +
            sevenHtml +
            detailHtml +
            contextHtml;
          statusEl?.classList.add('hidden');
          hideSkeleton();
          rootEl.classList.remove('hidden');

          // Favorite star: build the Favorite from the parsed URL params.
          const store = window.localStorage;
          const fav = {
            lat: loc.lat,
            lng: loc.lng,
            name: loc.name || `${loc.lat},${loc.lng}`,
            admin: loc.admin,
            tz: loc.tz,
            addedAt: Date.now(),
          };
          const favBtn = document.getElementById('fc-fav');
          const favIcon = document.getElementById('fc-fav-icon');
          const favSaved = document.getElementById('fc-fav-saved');
          function sync(): void {
            if (!favBtn) return;
            const on = has(store, loc.lat, loc.lng);
            if (favIcon) favIcon.textContent = on ? '★' : '☆';
            favBtn.classList.toggle('text-amber-400', on);
            favBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
            const label = on ? 'Quitar de favoritos' : 'Agregar a favoritos';
            favBtn.setAttribute('aria-label', label);
            favBtn.setAttribute('title', label);
            if (favSaved) favSaved.classList.toggle('hidden', !on);
          }
          if (favBtn) {
            favBtn.addEventListener('click', () => {
              toggle(store, { ...fav, addedAt: Date.now() });
              sync();
            });
            sync();
          }

          // Personal alerts (plan 3.5). Local-only — rules in localStorage.
          const alertBtn = document.getElementById('fc-alert');
          const alertPanel = document.getElementById('fc-alert-panel');
          const alertList = document.getElementById('fc-alert-list');
          const alertBanner = document.getElementById('fc-alert-banner');
          const alertMetricSel = document.getElementById(
            'fc-alert-metric',
          ) as HTMLSelectElement | null;
          const alertOpSel = document.getElementById(
            'fc-alert-op',
          ) as HTMLSelectElement | null;
          const alertThrInput = document.getElementById(
            'fc-alert-thr',
          ) as HTMLInputElement | null;
          const alertSaveBtn = document.getElementById('fc-alert-save');

          const metricLabels: Record<string, string> = {
            rain: 'Lluvia',
            temp_hi: 'Temp. máx.',
            temp_lo: 'Temp. mín.',
            wind: 'Viento',
          };
          const metricUnits: Record<string, string> = {
            rain: 'mm/h',
            temp_hi: '°C',
            temp_lo: '°C',
            wind: 'km/h',
          };

          function refreshAlertList(): void {
            if (!alertList) return;
            const rules = alertsForLocation(store, loc.lat, loc.lng);
            if (rules.length === 0) {
              alertList.innerHTML =
                '<li class="text-blue-700/60 dark:text-blue-300/60">Sin alertas para este lugar.</li>';
              return;
            }
            alertList.innerHTML = rules
              .map((r) => {
                const ml = metricLabels[r.metric] ?? r.metric;
                const u = metricUnits[r.metric] ?? '';
                return (
                  `<li class="flex items-center gap-2">` +
                  `<span class="flex-1">${ml} ${esc(r.op)} ${r.threshold}${esc(u)}</span>` +
                  `<button type="button" data-metric="${esc(r.metric)}" class="fc-alert-rm rounded border border-blue-300 px-1.5 text-[11px] hover:bg-blue-100 dark:border-blue-700 dark:hover:bg-blue-900">Quitar</button>` +
                  `</li>`
                );
              })
              .join('');
            alertList.querySelectorAll('.fc-alert-rm').forEach((b) => {
              b.addEventListener('click', () => {
                const m = (b as HTMLElement).dataset.metric as
                  | AlertMetric
                  | undefined;
                if (!m) return;
                removeAlert(store, loc.lat, loc.lng, m);
                refreshAlertList();
                renderAlertBanner();
              });
            });
          }

          function renderAlertBanner(): void {
            if (!alertBanner) return;
            const rules = alertsForLocation(store, loc.lat, loc.lng);
            if (rules.length === 0) {
              alertBanner.classList.add('hidden');
              alertBanner.innerHTML = '';
              return;
            }
            const hTemps = hourly
              .slice(0, 24)
              .map((hw) => hw.temperature)
              .filter((n): n is number => n !== null && Number.isFinite(n));
            const hPrecip = hourly
              .slice(0, 24)
              .map((hw) => hw.precipProbability)
              .filter((n): n is number => Number.isFinite(n));
            const hWind = hourly
              .slice(0, 24)
              .map((hw) => hw.windSpeed)
              .filter((n): n is number => Number.isFinite(n));
            const summary = {
              // Open-Meteo hourly we have is precipitation_probability not
              // amount; using it as a proxy for "expected rain intensity"
              // is rough but the API doesn't include precipitation here.
              // Threshold-as-probability still works (user picks 50, etc.).
              maxRainMmH: hPrecip.length ? Math.max(...hPrecip) : 0,
              maxTempC: hTemps.length ? Math.max(...hTemps) : 0,
              minTempC: hTemps.length ? Math.min(...hTemps) : 0,
              maxWindKmh: hWind.length ? Math.max(...hWind) : 0,
            };
            const fired = evaluateAlerts(rules, summary);
            if (fired.length === 0) {
              alertBanner.classList.add('hidden');
              alertBanner.innerHTML = '';
              return;
            }
            alertBanner.innerHTML =
              '<div class="font-semibold mb-0.5">⚠️ Alertas disparadas (próximas 24 h):</div>' +
              '<ul class="space-y-0.5 text-xs">' +
              fired
                .map((f) => {
                  const ml = metricLabels[f.rule.metric] ?? f.rule.metric;
                  const u = metricUnits[f.rule.metric] ?? '';
                  return (
                    `<li>${ml} ${esc(f.rule.op)} ${f.rule.threshold}${esc(u)} — alcanza ` +
                    `${Math.round(f.value)}${esc(u)}.</li>`
                  );
                })
                .join('') +
              '</ul>';
            alertBanner.classList.remove('hidden');
          }

          if (alertBtn) {
            alertBtn.addEventListener('click', () => {
              if (!alertPanel) return;
              const willShow = alertPanel.classList.contains('hidden');
              alertPanel.classList.toggle('hidden', !willShow);
              if (willShow) refreshAlertList();
            });
          }
          if (alertSaveBtn) {
            alertSaveBtn.addEventListener('click', () => {
              if (!alertMetricSel || !alertOpSel || !alertThrInput) return;
              const metric = alertMetricSel.value as AlertMetric;
              const op = alertOpSel.value as '>' | '<';
              const thr = parseFloat(alertThrInput.value);
              if (!Number.isFinite(thr)) return;
              const rule: AlertRule = {
                lat: loc.lat,
                lng: loc.lng,
                name: safeName || `${loc.lat}, ${loc.lng}`,
                metric,
                op,
                threshold: thr,
                createdAt: Date.now(),
              };
              addAlert(store, rule);
              refreshAlertList();
              renderAlertBanner();
            });
          }
          renderAlertBanner();

          // Share button: native Web Share with clipboard fallback + toast.
          const shareBtn = document.getElementById('fc-share');
          const shareToast = document.getElementById('fc-share-toast');
          let toastTimer: number | undefined;
          function flashToast(): void {
            if (!shareToast) return;
            shareToast.classList.remove('hidden');
            if (toastTimer) window.clearTimeout(toastTimer);
            toastTimer = window.setTimeout(() => {
              shareToast.classList.add('hidden');
            }, 2000);
          }
          if (shareBtn) {
            shareBtn.addEventListener('click', async () => {
              const shareUrl = location.href;
              const shareTitle = title;
              const nav = navigator as Navigator & {
                share?: (data: { title?: string; url?: string }) => Promise<void>;
              };
              try {
                if (typeof nav.share === 'function') {
                  await nav.share({ title: shareTitle, url: shareUrl });
                  return;
                }
              } catch {
                // user cancelled or share failed — fall through to clipboard
              }
              try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                  await navigator.clipboard.writeText(shareUrl);
                  flashToast();
                }
              } catch {
                // clipboard unavailable — silently no-op
              }
            });
          }

          // Last-updated timestamp: shown after each successful render.
          const updatedEl = document.getElementById('fc-updated');
          if (updatedEl) {
            const resolvedTz =
              loc.tz && loc.tz !== 'auto'
                ? loc.tz
                : Intl.DateTimeFormat().resolvedOptions().timeZone;
            let timeStr: string;
            try {
              timeStr = new Intl.DateTimeFormat(dateLocale, {
                hour: '2-digit',
                minute: '2-digit',
                hour12: false,
                timeZone: resolvedTz,
              }).format(new Date());
            } catch {
              timeStr = new Intl.DateTimeFormat(dateLocale, {
                hour: '2-digit',
                minute: '2-digit',
                hour12: false,
              }).format(new Date());
            }
            updatedEl.textContent = `Última actualización: ${timeStr} · ${resolvedTz}`;
          }

          // Climate anomaly (plan 3.6). How does today's forecast Tmax
          // compare to the 10-year mean for the same day-of-year? Open-
          // Meteo's free archive API (ERA5-Land) is keyless + CORS.
          // Background-fetched so it never blocks the page.
          const anomalyEl = document.getElementById('fc-anomaly');
          if (anomalyEl && d0 && d0.tmax !== null && d0.date) {
            const monthDay = d0.date.slice(5); // YYYY-MM-DD → MM-DD
            getClimateAnomaly(
              { lat: loc.lat, lng: loc.lng, tz: loc.tz },
              d0.tmax,
              monthDay,
              {
                fetch: window.fetch.bind(window),
                sleep: (ms: number) =>
                  new Promise<void>((r) => setTimeout(r, ms)),
                // Static baseline shipped by the climate-baseline GH
                // Action. When the closest known metro is within 100 km
                // we skip the live archive fetch entirely.
                baseUrl: import.meta.env.BASE_URL,
              },
            )
              .then((a) => {
                if (!a) return;
                // Hide entirely when |Δ| < 1° — within seasonal noise,
                // no signal worth surfacing.
                if (Math.abs(a.anomalyC) < 1) return;
                const sign = a.anomalyC >= 0 ? '+' : '';
                const abs = Math.abs(a.anomalyC);
                // Severity ramps: 1-3° = mild (light), 3-5° = notable
                // (medium), 5°+ = striking (strong). Symmetric for
                // hotter/cooler.
                const TWS = {
                  hot5: 'bg-red-100 text-red-900 ring-red-400 dark:bg-red-950 dark:text-red-200 dark:ring-red-700',
                  hot3: 'bg-orange-100 text-orange-900 ring-orange-300 dark:bg-orange-950 dark:text-orange-200 dark:ring-orange-800',
                  hot1: 'bg-amber-100 text-amber-900 ring-amber-300 dark:bg-amber-950 dark:text-amber-200 dark:ring-amber-800',
                  cold5: 'bg-blue-100 text-blue-900 ring-blue-400 dark:bg-blue-950 dark:text-blue-200 dark:ring-blue-700',
                  cold3: 'bg-sky-100 text-sky-900 ring-sky-300 dark:bg-sky-950 dark:text-sky-200 dark:ring-sky-800',
                  cold1: 'bg-cyan-100 text-cyan-900 ring-cyan-300 dark:bg-cyan-950 dark:text-cyan-200 dark:ring-cyan-800',
                };
                let tw: string;
                let label: string;
                if (a.anomalyC >= 5) { tw = TWS.hot5; label = 'Mucho más cálido'; }
                else if (a.anomalyC >= 3) { tw = TWS.hot3; label = 'Más cálido'; }
                else if (a.anomalyC >= 1) { tw = TWS.hot1; label = 'Algo más cálido'; }
                else if (a.anomalyC <= -5) { tw = TWS.cold5; label = 'Mucho más fresco'; }
                else if (a.anomalyC <= -3) { tw = TWS.cold3; label = 'Más fresco'; }
                else { tw = TWS.cold1; label = 'Algo más fresco'; }
                const tooltip =
                  `vs. promedio ${a.yearsUsed} años (${a.baselineTmax.toFixed(1)}°)`;
                anomalyEl.innerHTML =
                  `<span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium ring-1 ${tw}" title="${tooltip}">` +
                  `<span aria-hidden="true">${a.anomalyC > 0 ? '🔥' : '❄️'}</span>` +
                  `<span>${sign}${abs.toFixed(1)}°C ${label}</span>` +
                  `</span>` +
                  `<span class="ml-2 text-xs text-gray-500 dark:text-gray-400">${tooltip}</span>`;
                anomalyEl.classList.remove('hidden');
              })
              .catch(() => {
                /* enhancement-only — silent on failure */
              });
          }

          // Multi-model disagreement (plan 3.4). zoom.earth shows only one
          // operational model; here we surface the spread across ICON
          // (DWD), GFS (NOAA), ECMWF and JMA so users can judge confidence.
          // Background-fetched: never blocks the main render.
          const modelsEl = document.getElementById('fc-models');
          if (modelsEl) {
            getModelDisagreement(
              { lat: loc.lat, lng: loc.lng, tz: loc.tz },
              {
                fetch: window.fetch.bind(window),
                sleep: (ms: number) =>
                  new Promise<void>((r) => setTimeout(r, ms)),
              },
            )
              .then((d) => {
                const parts: string[] = [];
                const labels: Record<string, string> = {
                  icon_seamless: 'ICON',
                  gfs_seamless: 'GFS',
                  ecmwf_ifs04: 'ECMWF',
                  jma_seamless: 'JMA',
                };
                for (const [k, v] of Object.entries(d.byModel)) {
                  if (v !== null) {
                    parts.push(
                      `${labels[k] ?? k} ${Math.round(v as number)}°`,
                    );
                  }
                }
                if (parts.length < 2 || d.spread === null) return;
                const spreadColor =
                  d.spread <= 1
                    ? 'text-green-600 dark:text-green-400'
                    : d.spread <= 3
                      ? 'text-yellow-600 dark:text-yellow-400'
                      : 'text-orange-600 dark:text-orange-400';
                modelsEl.innerHTML =
                  `<span class="font-semibold">Modelos:</span> ${parts.join(' · ')} ` +
                  `<span class="${spreadColor}">(desacuerdo ${d.spread.toFixed(1)}°)</span>`;
                modelsEl.classList.remove('hidden');
              })
              .catch(() => {
                /* enhancement-only — silent on failure */
              });
          }

          // Embedded INTERACTIVE map for the location.
          //
          // Was a 160-px static click-through; now a 320–360 px MapLibre
          // instance (pan/zoom + marker popup) backed by the shared
          // factory at src/lib/interactive-map.ts. Layer rail, search and
          // timeline are off — for those, users tap "Abrir mapa a pantalla
          // completa →" below the embed, which deep-links to /mapa with
          // the current location preserved in the URL hash.
          const mapEl = document.getElementById('fc-map');
          if (mapEl) {
            window.requestAnimationFrame(() => {
              void initInteractiveMap({
                els: { container: mapEl },
                features: {
                  layerRail: false,
                  timeline: false,
                  search: false,
                  locateButton: false,
                  // We render our own marker below (location-specific
                  // popup with full-forecast link); skip preset pins to
                  // keep the embed focused.
                  presetPins: false,
                },
                initialView: { lat: loc.lat, lng: loc.lng, zoom: 9 },
                // Default to the temperature field layer so the user sees
                // weather data near their location immediately instead of a
                // bare basemap. Hash overrides this when present.
                initialLayer: 'temperature',
                useHash: false,
                exposeE2eHook: false,
                interactive: true,
                markerPopups: true,
                lang,
              })
                .then((handle) => {
                  // Add the user's marker once the map is loaded.
                  handle.map.once('load', () => {
                    void import('maplibre-gl').then((mod) => {
                      const ml =
                        (mod as { default?: typeof import('maplibre-gl') })
                          .default ?? mod;
                      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
                      const fcUrl = `${baseUrl}/forecast?lat=${loc.lat}&lng=${loc.lng}&name=${encodeURIComponent(loc.name || '')}`;
                      const popupHtml =
                        `<div class="text-sm"><strong>${esc(loc.name || (loc.lat + ', ' + loc.lng))}</strong><br>` +
                        `<a href="${esc(fcUrl)}" class="text-blue-600 underline">${esc(t.full_forecast)} →</a></div>`;
                      const popup = new ml.Popup({ offset: 24 }).setHTML(popupHtml);
                      const fcMarker = new ml.Marker({ color: '#2563eb' })
                        .setLngLat([loc.lng, loc.lat])
                        .setPopup(popup)
                        .addTo(handle.map);
                      // a11y: MapLibre's default aria-label on a role-less
                      // div trips axe-core. Promote to role=button + name.
                      try {
                        const mEl = fcMarker.getElement();
                        mEl.setAttribute('role', 'button');
                        mEl.setAttribute(
                          'aria-label',
                          loc.name ? `Marcador: ${loc.name}` : 'Marcador en el mapa',
                        );
                      } catch {
                        /* best-effort */
                      }
                    });
                  });
                })
                .catch(() => {
                  /* MapLibre failed to load (offline, blocked) — keep the
                     placeholder block + click-through link. No throw. */
                });
            });
          }
        }
      } catch {
        hideSkeleton();
        if (statusEl) {
          statusEl.textContent = t.load_error;
          statusEl.classList.remove('sr-only', 'text-gray-600', 'dark:text-gray-500');
          statusEl.classList.add('text-red-600', 'dark:text-red-400');
        }
      }
    }

    // --- param parsing --------------------------------------------------
    const params = new URLSearchParams(location.search);
    const latRaw = params.get('lat');
    const lngRaw = params.get('lng');
    const name = params.get('name') || '';
    const admin = params.get('admin') || '';
    const tz = params.get('tz') || 'auto';

    const lat = latRaw === null ? NaN : Number(latRaw);
    const lng = lngRaw === null ? NaN : Number(lngRaw);

    const valid =
      latRaw !== null &&
      lngRaw !== null &&
      Number.isFinite(lat) &&
      Number.isFinite(lng) &&
      lat >= -90 &&
      lat <= 90 &&
      lng >= -180 &&
      lng <= 180;

    if (!valid) {
      showEmpty();
    } else {
      void render({ lat, lng, tz, name, admin });
    }
  </script>
</BaseLayout>
