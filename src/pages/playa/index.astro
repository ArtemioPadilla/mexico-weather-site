---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOP_BEACHES } from '../../lib/top-beaches';
import { siteBase } from '../../utils/paths';
import { breadcrumbLd } from '../../lib/structured-data';

const base = siteBase();
const title = 'Playas de México — Clima, oleaje y temperatura del mar';
const titleEn = 'Beaches of Mexico — Weather, surf and sea temperature';
const description =
  'Estado del mar en las principales playas y destinos costeros de México: ' +
  'Cancún, Playa del Carmen, Los Cabos, Puerto Vallarta y más. ' +
  'Altura de las olas y temperatura del mar de Open-Meteo Marine.';
const descriptionEn =
  'Sea state at major Mexican beaches and coastal destinations: ' +
  'Cancún, Playa del Carmen, Los Cabos, Puerto Vallarta and more. ' +
  'Wave height and sea-surface temperature from Open-Meteo Marine.';
const canonical = new URL(`${base}playa/`, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Playas de México',
    url: canonical,
    inLanguage: 'es-MX',
    description,
  },
  breadcrumbLd([
    { name: 'Inicio', url: homeUrl },
    { name: 'Playas', url: canonical },
  ]),
];

const beaches = [...TOP_BEACHES].sort((a, b) => a.name.localeCompare(b.name, 'es'));
---

<BaseLayout
  title={title}
  description={description}
  titleEn={titleEn}
  descriptionEn={descriptionEn}
  lang="es"
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <nav aria-label="breadcrumb" class="text-sm">
        <ol class="flex flex-wrap items-center gap-1 text-gray-600 dark:text-gray-400">
          <li>
            <a
              href={base}
              class="inline-flex min-h-[44px] items-center hover:text-gray-900 dark:hover:text-gray-200 underline"
              data-i18n-en="Home"
            >
              Inicio
            </a>
          </li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-900 dark:text-gray-100" aria-current="page" data-i18n-en="Beaches">Playas</li>
        </ol>
      </nav>

      <header class="space-y-2">
        <h1
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          data-i18n-en-html={`<span aria-hidden="true">🌊</span> Beaches of Mexico`}
        >
          <span aria-hidden="true">🌊</span> Playas de México
        </h1>
        <p
          class="text-base text-gray-700 dark:text-gray-300"
          data-i18n-en={`Sea state at the ${beaches.length} major coastal destinations of Mexico. Wave height and water temperature updated hourly from the Open-Meteo marine model.`}
        >
          Estado del mar en los {beaches.length} principales destinos costeros de México.
          Altura de las olas y temperatura del agua actualizados cada hora desde el modelo
          marino de Open-Meteo.
        </p>
      </header>

      <input
        id="catalog-filter"
        type="search"
        placeholder="Filtrar por nombre o estado…"
        data-i18n-en-placeholder="Filter by name or state…"
        aria-label="Filtrar playas"
        data-i18n-en-aria-label="Filter beaches"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-500 dark:border-gray-700 dark:bg-gray-900"
      />
      <ul id="catalog-list" class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        {
          beaches.map((b) => (
            <li
              data-catalog-item
              data-search={`${b.name} ${b.admin}`
                .toLowerCase()
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')}
            >
              <a
                href={`${base}playa/${b.slug}/`}
                class="block rounded-md border border-gray-200 p-3 hover:border-cyan-500/40 dark:border-gray-800 dark:hover:border-cyan-500/40"
              >
                <div class="font-medium">{b.name}</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">{b.admin}</div>
              </a>
            </li>
          ))
        }
      </ul>
      <p
        id="catalog-empty"
        class="hidden text-sm text-gray-500 dark:text-gray-400"
        data-i18n-en="No results."
      >
        Sin resultados.
      </p>
      <script is:inline>
        (function () {
          var input = document.getElementById('catalog-filter');
          var empty = document.getElementById('catalog-empty');
          if (!input) return;
          function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, ''); }
          var timer;
          input.addEventListener('input', function () {
            window.clearTimeout(timer);
            timer = window.setTimeout(function () {
              var q = norm(input.value.trim());
              var items = document.querySelectorAll('[data-catalog-item]');
              var visible = 0;
              items.forEach(function (li) {
                var match = !q || (li.getAttribute('data-search') || '').indexOf(q) !== -1;
                li.classList.toggle('hidden', !match);
                if (match) visible++;
              });
              if (empty) empty.classList.toggle('hidden', visible > 0);
            }, 100);
          });
        })();
      </script>
    </div>
  </main>
</BaseLayout>
