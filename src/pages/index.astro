---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cities } from '../data/cities';
---

<BaseLayout title="Clima México 🇲🇽" description="Alertas y pronósticos meteorológicos para México" lang="es">
  <main class="min-h-screen bg-gray-950 text-gray-100">
    <!-- Hero -->
    <div class="max-w-5xl mx-auto px-4 py-12 space-y-10">
      <div class="text-center space-y-4">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-400">
          <span class="h-2 w-2 rounded-full bg-blue-400 animate-pulse"></span>
          Actualizado cada 10 minutos
        </div>
        <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
          Clima México 🇲🇽
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
          Pronósticos y alertas meteorológicas del SMN + Open-Meteo para las principales ciudades de México.
        </p>
        <p id="js-updated-at" class="text-xs text-gray-500" aria-live="polite">Cargando datos más recientes...</p>
      </div>

      <!-- Alertas activas -->
      <div class="rounded-xl border border-yellow-500/30 bg-yellow-500/10 p-5 space-y-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl">⚠️</span>
          <h2 class="text-lg font-semibold text-yellow-300">Alertas Activas — SMN</h2>
        </div>
        <p class="text-sm text-gray-400">
          Consulta el feed RSS del Servicio Meteorológico Nacional para alertas en tiempo real:
        </p>
        <a
          href="https://artemiop.com/mexico-weather/rss.xml"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-yellow-500/30 bg-yellow-500/10 px-4 py-2 text-sm font-medium text-yellow-300 hover:bg-yellow-500/20 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          Feed RSS del SMN
        </a>
      </div>

      <!-- Ciudades -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-200">Pronóstico por Ciudad</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">

          {cities.map((city) => (
            <div
              class="rounded-xl border border-gray-800 bg-gray-900 p-5 space-y-3 hover:border-blue-500/40 transition-colors"
              data-city-card
              data-lat={city.lat}
              data-lng={city.lng}
              data-tz={city.tz}
            >
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-2xl">{city.emoji}</div>
                  <h3 class="font-semibold text-white mt-1">{city.name}</h3>
                  <p class="text-xs text-gray-500">{city.lat}°N, {Math.abs(city.lng)}°W</p>
                </div>
              </div>
              <p class="text-sm text-gray-500 js-status" aria-live="polite">Cargando pronóstico...</p>
              <div class="space-y-1 hidden js-weather">
                <p class="text-2xl font-bold text-white"><span class="js-tmax">--</span>° / <span class="js-tmin">--</span>°C</p>
                <p class="text-sm text-gray-400 js-condition">—</p>
                <p class="text-sm text-blue-400">💧 <span class="js-rain">--</span>% lluvia</p>
              </div>
              <a
                href={`https://open-meteo.com/en/docs?latitude=${city.lat}&longitude=${city.lng}&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode&timezone=America/Mexico_City`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
              >
                Ver en Open-Meteo →
              </a>
            </div>
          ))}

          <!-- Más ciudades pronto -->
          <div class="rounded-xl border border-dashed border-gray-700 bg-gray-900/50 p-5 space-y-3 flex items-center justify-center">
            <div class="text-center space-y-2">
              <div class="text-2xl">➕</div>
              <p class="text-sm text-gray-500">Más ciudades próximamente</p>
              <a
                href="https://github.com/ArtemioPadilla/mexico-weather-site/issues/new?template=feature_request.yml"
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
              >
                Sugerir ciudad →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="border-t border-gray-800 pt-6 text-center space-y-2">
        <p class="text-xs text-gray-500">Fuentes de datos:</p>
        <div class="flex flex-wrap justify-center gap-4 text-xs text-gray-500">
          <a href="https://open-meteo.com" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">
            Open-Meteo (ECMWF/DWD/GFS)
          </a>
          <span>•</span>
          <a href="https://smn.conagua.gob.mx" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">
            SMN / CONAGUA
          </a>
        </div>
        <p class="text-xs text-gray-700 mt-2">
          Datos libres • Sin cookies • Sin rastreo
        </p>
      </footer>
    </div>
  </main>

  <script is:inline>
    (() => {
      const WMO = JSON.parse('{"0":"Despejado ☀️","1":"Despejado ☀️","2":"Parcialmente nublado ⛅","3":"Nublado ☁️","45":"Niebla 🌫️","48":"Niebla 🌫️","51":"Llovizna 🌦️","53":"Llovizna 🌦️","55":"Llovizna 🌦️","61":"Lluvia 🌧️","63":"Lluvia 🌧️","65":"Lluvia intensa 🌧️","71":"Nieve 🌨️","73":"Nieve 🌨️","75":"Nieve intensa 🌨️","80":"Chubascos 🌩️","81":"Chubascos 🌩️","82":"Tormenta ⛈️","95":"Tormenta ⛈️","96":"Tormenta con granizo ⛈️","99":"Tormenta con granizo ⛈️"}');
      const cards = Array.from(document.querySelectorAll('[data-city-card]'));
      const updatedAt = document.getElementById('js-updated-at');

      function setUpdatedAtMessage() {
        if (!updatedAt) return;
        const now = new Date();
        const time = now.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
        updatedAt.textContent = `Última actualización: ${time}`;
      }

      function renderError(card) {
        const status = card.querySelector('.js-status');
        const weather = card.querySelector('.js-weather');
        if (status) {
          status.textContent = 'Error cargando datos. Reintentando...';
          status.classList.remove('text-gray-500');
          status.classList.add('text-red-400');
        }
        if (weather) weather.classList.add('hidden');
      }

      function renderSuccess(card, payload) {
        const status = card.querySelector('.js-status');
        const weather = card.querySelector('.js-weather');
        const tmax = card.querySelector('.js-tmax');
        const tmin = card.querySelector('.js-tmin');
        const rain = card.querySelector('.js-rain');
        const condition = card.querySelector('.js-condition');

        if (tmax) tmax.textContent = String(payload.tmax);
        if (tmin) tmin.textContent = String(payload.tmin);
        if (rain) rain.textContent = String(payload.rain);
        if (condition) condition.textContent = payload.condition;
        if (status) status.classList.add('hidden');
        if (weather) weather.classList.remove('hidden');
      }

      async function refreshCard(card) {
        const lat = card.getAttribute('data-lat');
        const lng = card.getAttribute('data-lng');
        const tz = card.getAttribute('data-tz') || 'America/Mexico_City';
        if (!lat || !lng) return;

        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode&timezone=${tz}&forecast_days=1&models=best_match`;
        try {
          const response = await fetch(url, { cache: 'no-store' });
          if (!response.ok) throw new Error('Weather request failed');
          const data = await response.json();
          const daily = data?.daily;
          if (!daily) throw new Error('Invalid weather response');

          const tmax = daily.temperature_2m_max?.[0];
          const tmin = daily.temperature_2m_min?.[0];
          const rain = daily.precipitation_probability_max?.[0];
          const weatherCode = daily.weathercode?.[0];
          if (tmax == null || tmin == null || rain == null || weatherCode == null) {
            throw new Error('Missing weather fields');
          }

          renderSuccess(card, {
            tmax,
            tmin,
            rain,
            condition: WMO[String(weatherCode)] || '—',
          });
        } catch {
          renderError(card);
        }
      }

      async function refreshAll() {
        await Promise.all(cards.map((card) => refreshCard(card)));
        setUpdatedAtMessage();
      }

      refreshAll();
      window.setInterval(refreshAll, 10 * 60 * 1000);
    })();
  </script>
</BaseLayout>
