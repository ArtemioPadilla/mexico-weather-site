---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Clima México 🇲🇽" description="Alertas y pronósticos meteorológicos para México" lang="es">
  <main class="min-h-screen bg-gray-950 text-gray-100">
    <!-- Hero -->
    <div class="max-w-5xl mx-auto px-4 py-12 space-y-10">
      <div class="text-center space-y-4">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-400">
          <span class="h-2 w-2 rounded-full bg-blue-400 animate-pulse"></span>
          Actualizado en tiempo real
        </div>
        <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
          Clima México 🇲🇽
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
          Pronósticos y alertas meteorológicas del SMN + Open-Meteo para las principales ciudades de México.
        </p>
      </div>

      <!-- Alertas activas -->
      <div class="rounded-xl border border-yellow-500/30 bg-yellow-500/10 p-5 space-y-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl">⚠️</span>
          <h2 class="text-lg font-semibold text-yellow-300">Alertas Activas — SMN</h2>
        </div>
        <p class="text-sm text-gray-400">
          Consulta el feed RSS del Servicio Meteorológico Nacional para alertas en tiempo real:
        </p>
        <a
          href="https://ArtemioPadilla.github.io/mexico-weather/rss.xml"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-yellow-500/30 bg-yellow-500/10 px-4 py-2 text-sm font-medium text-yellow-300 hover:bg-yellow-500/20 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          Feed RSS del SMN
        </a>
      </div>

      <!-- Ciudades -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-200">Pronóstico por Ciudad</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">

          <!-- CDMX -->
          <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 space-y-3 hover:border-blue-500/40 transition-colors">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-2xl">🌆</div>
                <h3 class="font-semibold text-white mt-1">Ciudad de México</h3>
                <p class="text-xs text-gray-500">19.43°N, 99.13°W</p>
              </div>
            </div>
            <a
              href="https://open-meteo.com/en/docs?latitude=19.43&longitude=-99.13&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode&timezone=America/Mexico_City"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
            >
              Ver en Open-Meteo →
            </a>
          </div>

          <!-- Oaxaca -->
          <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 space-y-3 hover:border-blue-500/40 transition-colors">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-2xl">🏔️</div>
                <h3 class="font-semibold text-white mt-1">Oaxaca</h3>
                <p class="text-xs text-gray-500">17.07°N, 96.72°W</p>
              </div>
            </div>
            <a
              href="https://open-meteo.com/en/docs?latitude=17.07&longitude=-96.72&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode&timezone=America/Mexico_City"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
            >
              Ver en Open-Meteo →
            </a>
          </div>

          <!-- Puerto Vallarta -->
          <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 space-y-3 hover:border-blue-500/40 transition-colors">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-2xl">🌊</div>
                <h3 class="font-semibold text-white mt-1">Puerto Vallarta</h3>
                <p class="text-xs text-gray-500">20.65°N, 105.25°W</p>
              </div>
            </div>
            <a
              href="https://open-meteo.com/en/docs?latitude=20.65&longitude=-105.25&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode&timezone=America/Mexico_City"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
            >
              Ver en Open-Meteo →
            </a>
          </div>

          <!-- Monterrey -->
          <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 space-y-3 hover:border-blue-500/40 transition-colors">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-2xl">🏙️</div>
                <h3 class="font-semibold text-white mt-1">Monterrey</h3>
                <p class="text-xs text-gray-500">25.67°N, 100.31°W</p>
              </div>
            </div>
            <a
              href="https://open-meteo.com/en/docs?latitude=25.67&longitude=-100.31&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode&timezone=America/Mexico_City"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
            >
              Ver en Open-Meteo →
            </a>
          </div>

          <!-- Guadalajara -->
          <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 space-y-3 hover:border-blue-500/40 transition-colors">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-2xl">🌺</div>
                <h3 class="font-semibold text-white mt-1">Guadalajara</h3>
                <p class="text-xs text-gray-500">20.66°N, 103.35°W</p>
              </div>
            </div>
            <a
              href="https://open-meteo.com/en/docs?latitude=20.66&longitude=-103.35&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode&timezone=America/Mexico_City"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
            >
              Ver en Open-Meteo →
            </a>
          </div>

          <!-- Más ciudades pronto -->
          <div class="rounded-xl border border-dashed border-gray-700 bg-gray-900/50 p-5 space-y-3 flex items-center justify-center">
            <div class="text-center space-y-2">
              <div class="text-2xl">➕</div>
              <p class="text-sm text-gray-500">Más ciudades próximamente</p>
              <a
                href="https://github.com/ArtemioPadilla/mexico-weather-site/issues/new?template=feature_request.yml"
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-blue-400 hover:text-blue-300 transition-colors"
              >
                Sugerir ciudad →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="border-t border-gray-800 pt-6 text-center space-y-2">
        <p class="text-xs text-gray-500">Fuentes de datos:</p>
        <div class="flex flex-wrap justify-center gap-4 text-xs text-gray-500">
          <a href="https://open-meteo.com" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">
            Open-Meteo (ECMWF/DWD/GFS)
          </a>
          <span>•</span>
          <a href="https://smn.conagua.gob.mx" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">
            SMN / CONAGUA
          </a>
        </div>
        <p class="text-xs text-gray-700 mt-2">
          Datos libres • Sin cookies • Sin rastreo
        </p>
      </footer>
    </div>
  </main>
</BaseLayout>
