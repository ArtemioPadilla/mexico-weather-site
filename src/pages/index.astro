---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cities } from '../data/cities';
import { ui } from '../i18n/ui';
import { siteBase } from '../utils/paths';

const t = ui.es;
const base = siteBase();
---

<BaseLayout title="Clima México 🇲🇽" description="Alertas y pronósticos meteorológicas para México" lang="es">
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <!-- Hero -->
    <div class="max-w-5xl mx-auto px-4 py-12 space-y-10">
      <div class="text-center space-y-4">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/40 bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-600 dark:border-blue-500/30 dark:text-blue-400">
          <span class="h-2 w-2 rounded-full bg-blue-500 dark:bg-blue-400 animate-pulse"></span>
          Actualizado cada 10 minutos
        </div>
        <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
          Clima México 🇲🇽
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
          Pronósticos y alertas meteorológicas del SMN + Open-Meteo para las principales ciudades de México.
        </p>
        <div class="max-w-xl mx-auto mt-6">
          <div class="flex gap-2">
            <input id="q" type="text" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="ac" aria-autocomplete="list" aria-label={t.search_placeholder} placeholder={t.search_placeholder} class="flex-1 bg-white border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-900 dark:border-gray-700 dark:text-gray-100" />
            <button id="geo" type="button" class="bg-white border border-gray-300 rounded-lg px-3 text-sm text-blue-700 hover:bg-gray-50 dark:bg-gray-900 dark:border-gray-700 dark:text-blue-300 dark:hover:bg-gray-800 motion-reduce:transition-none"><span aria-hidden="true">📍</span> {t.use_my_location}</button>
          </div>
          <ul id="ac" role="listbox" class="hidden mt-1 bg-white border border-gray-300 rounded-lg overflow-hidden dark:bg-gray-900 dark:border-gray-700"></ul>
          <p id="qmsg" class="hidden mt-1 text-xs text-gray-600 dark:text-gray-500" aria-live="polite"></p>
        </div>
        <p id="js-updated-at" class="text-xs text-gray-600 dark:text-gray-500" aria-live="polite">Cargando datos más recientes...</p>
      </div>

      <!-- Alertas activas -->
      <div class="rounded-xl border border-yellow-500/40 bg-yellow-500/10 p-5 space-y-3 dark:border-yellow-500/30">
        <div class="flex items-center gap-2">
          <span class="text-2xl">⚠️</span>
          <h2 class="text-lg font-semibold text-yellow-700 dark:text-yellow-300">Alertas Activas — SMN</h2>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Consulta nuestro feed RSS con avisos meteorológicos derivados de los datos oficiales del SMN:
        </p>
        <a
          href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/rss.xml`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-yellow-500/40 bg-yellow-500/10 px-4 py-2 text-sm font-medium text-yellow-700 hover:bg-yellow-500/20 transition-colors dark:border-yellow-500/30 dark:text-yellow-300"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          Feed RSS del SMN
        </a>
      </div>

      <script id="preset-data" type="application/json" is:inline set:html={JSON.stringify(cities).replace(/</g, '\\u003c')}></script>

      <!-- Tus lugares (favoritos, llenado por el cliente) -->
      <section id="fav-section" class="hidden mb-8" aria-label="Tus lugares">
        <h2 class="text-lg font-semibold mb-3 flex items-center gap-2"><span aria-hidden="true">⭐</span> Tus lugares</h2>
        <div id="fav-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
      </section>
      <p id="fav-msg" class="sr-only" aria-live="polite"></p>

      <!-- Ciudades -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Pronóstico por Ciudad</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">

          <!-- Tarjetas preset insertadas por el script (mismo render que favoritos) -->
          <div id="preset-grid" class="contents"></div>

          <!-- Más ciudades pronto -->
          <div class="rounded-xl border border-dashed border-gray-300 bg-gray-50 p-5 space-y-3 flex items-center justify-center dark:border-gray-700 dark:bg-gray-900/50">
            <div class="text-center space-y-2">
              <div class="text-2xl">➕</div>
              <p class="text-sm text-gray-600 dark:text-gray-500">Más ciudades próximamente</p>
              <a
                href="https://github.com/ArtemioPadilla/mexico-weather-site/issues/new?template=feature_request.yml"
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-blue-600 hover:text-blue-700 transition-colors dark:text-blue-400 dark:hover:text-blue-300"
              >
                Sugerir ciudad →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="border-t border-gray-200 pt-6 text-center space-y-2 dark:border-gray-800">
        <p class="text-xs text-gray-600 dark:text-gray-500">Fuentes de datos:</p>
        <div class="flex flex-wrap justify-center gap-4 text-xs text-gray-600 dark:text-gray-500">
          <a href="https://open-meteo.com" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors dark:hover:text-gray-300">
            Open-Meteo (ECMWF/DWD/GFS)
          </a>
          <span>•</span>
          <a href="https://smn.conagua.gob.mx" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors dark:hover:text-gray-300">
            SMN / CONAGUA
          </a>
        </div>
        <p class="text-xs text-gray-400 mt-2 dark:text-gray-700">
          Datos libres • Sin cookies • Sin rastreo
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-xs text-gray-600 dark:text-gray-500 mt-1">
          <a
            href={`${base}privacidad/`}
            class="hover:text-gray-900 transition-colors dark:hover:text-gray-300"
          >
            Privacidad
          </a>
          <span>•</span>
          <a
            href="https://artemiop.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gray-900 transition-colors dark:hover:text-gray-300"
          >
            Artemio Padilla
          </a>
        </div>
      </footer>
    </div>
  </main>

  <script>
    // Bundled module script (NOT is:inline) so the import is processed by Astro/Vite.
    import { getForecast, uvLabel, windDir } from '../lib/forecast';
    import { geocode } from '../lib/geocode';
    import { list, has, toggle, remove, type Favorite } from '../lib/favorites';
    import { ui } from '../i18n/ui';

    const t = ui.es;

    const REFRESH_INTERVAL_MS = 10 * 60 * 1000;

    const updatedAt = document.getElementById('js-updated-at');

    // Injected request deps shared by forecast + geocode SDK calls.
    const deps = {
      fetch: window.fetch.bind(window),
      sleep: (ms: number) => new Promise<void>((r) => window.setTimeout(r, ms)),
    };

    // Strip a trailing slash from the configured base path so we can safely
    // concatenate route paths.
    const base = (import.meta.env.BASE_URL as string).replace(/\/$/, '');

    function fullHref(
      lat: string,
      lng: string,
      tz: string,
      name: string,
      admin?: string,
    ): string {
      const p = new URLSearchParams({ lat, lng, tz, name });
      if (admin) p.set('admin', admin);
      return base + '/forecast?' + p.toString();
    }

    // Round a possibly-null number for display; null/undefined → em dash.
    function fmt(n: number | null | undefined): string {
      return n == null ? '—' : String(Math.round(n));
    }

    function setUpdatedAtMessage() {
      if (!updatedAt) return;
      const now = new Date();
      const time = now.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
      updatedAt.textContent = `Última actualización: ${time}`;
    }

    function setUpdateFailedMessage() {
      if (!updatedAt) return;
      updatedAt.textContent = 'No se pudo actualizar. Reintentando automáticamente.';
    }

    function setStatusMessage(card: Element, message: string, isError: boolean) {
      const status = card.querySelector('.js-status');
      const weather = card.querySelector('.js-weather');
      if (status) {
        status.textContent = message;
        status.classList.remove(
          'text-gray-600',
          'dark:text-gray-500',
          'text-red-600',
          'dark:text-red-400',
        );
        if (isError) {
          status.classList.add('text-red-600', 'dark:text-red-400');
        } else {
          status.classList.add('text-gray-600', 'dark:text-gray-500');
        }
        status.classList.remove('hidden');
      }
      if (weather) weather.classList.add('hidden');
    }

    function renderRetrying(card: Element) {
      // Accurate copy: a retry is genuinely in progress.
      setStatusMessage(card, 'Error al cargar. Reintentando...', true);
    }

    function renderTerminalError(card: Element) {
      // Attempts exhausted; the 10-minute interval is the only further retry.
      setStatusMessage(card, 'Error al cargar. Se reintentará automáticamente.', true);
    }

    interface PeekData {
      windSpeed: number;
      windDir: number;
      uvIndex: number;
      cloudCover: number;
      humidity: number;
    }

    function renderSuccess(
      card: Element,
      payload: {
        tmax: number | null;
        tmin: number | null;
        rain: number;
        condition: string;
        peek: PeekData;
      },
    ) {
      const status = card.querySelector('.js-status');
      const weather = card.querySelector('.js-weather');
      const tmax = card.querySelector('.js-tmax');
      const tmin = card.querySelector('.js-tmin');
      const rain = card.querySelector('.js-rain');
      const condition = card.querySelector('.js-condition');

      if (tmax) tmax.textContent = fmt(payload.tmax);
      if (tmin) tmin.textContent = fmt(payload.tmin);
      if (rain) rain.textContent = fmt(payload.rain);
      if (condition) condition.textContent = payload.condition;
      if (status) status.classList.add('hidden');
      if (weather) weather.classList.remove('hidden');

      // Cache the latest peek figures on the card for the toggle handler.
      (card as HTMLElement).dataset.peek = JSON.stringify(payload.peek);
      const box = card.querySelector('.js-peekbox');
      // Refresh the peek box in place if it is currently open.
      if (box && !box.classList.contains('hidden')) fillPeek(card);
    }

    // Build the quick-peek summary using textContent only (no innerHTML).
    function fillPeek(card: Element) {
      const box = card.querySelector('.js-peekbox');
      if (!box) return;
      const raw = (card as HTMLElement).dataset.peek;
      box.textContent = '';
      if (!raw) {
        const p = document.createElement('p');
        p.textContent = t.loading;
        box.appendChild(p);
        return;
      }
      const d: PeekData = JSON.parse(raw);
      const wd = windDir(d.windDir);
      const uv = uvLabel(d.uvIndex);
      const line = document.createElement('p');
      line.textContent =
        `💨 ${Math.round(d.windSpeed)} km/h ${wd.label}` +
        ` · ☀️ UV ${uv.value} (${uv.level})` +
        ` · ☁️ ${Math.round(d.cloudCover)}%` +
        ` · 💦 ${Math.round(d.humidity)}%`;
      box.appendChild(line);
    }

    // ---- Single source of truth for a city card -----------------------
    // Both the preset grid and the favorites grid build their cards here so
    // the markup/classes never diverge.
    interface CardSpec {
      lat: string;
      lng: string;
      name: string;
      tz: string;
      admin?: string;
    }

    function buildCityCardElement(spec: CardSpec): HTMLElement {
      const tz = spec.tz || 'America/Mexico_City';
      const card = document.createElement('div');
      card.className =
        'relative rounded-xl border border-gray-200 bg-white p-5 space-y-3 hover:border-blue-500/40 transition-colors dark:border-gray-800 dark:bg-gray-900';
      card.setAttribute('data-city-card', '');
      card.dataset.lat = spec.lat;
      card.dataset.lng = spec.lng;
      card.dataset.tz = tz;
      if (spec.admin) card.dataset.admin = spec.admin;

      // Star toggle (top-right, theme-aware, accessible).
      const star = document.createElement('button');
      star.type = 'button';
      star.className =
        'js-fav-star absolute top-2 right-2 text-lg leading-none text-gray-400 hover:text-amber-400 dark:text-gray-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 rounded';
      star.setAttribute('aria-pressed', 'false');
      star.setAttribute('aria-label', 'Agregar a favoritos');
      star.title = 'Agregar a favoritos';
      star.textContent = '☆';
      card.appendChild(star);

      const head = document.createElement('div');
      head.className = 'flex items-center justify-between';
      const headInner = document.createElement('div');
      const h3 = document.createElement('h3');
      h3.className = 'font-semibold text-gray-900 mt-1 dark:text-white';
      h3.textContent = spec.name;
      const coords = document.createElement('p');
      coords.className = 'text-xs text-gray-600 dark:text-gray-500';
      const latN = Number(spec.lat);
      const lngN = Number(spec.lng);
      coords.textContent =
        `${Number.isFinite(latN) ? latN : spec.lat}°N, ` +
        `${Number.isFinite(lngN) ? Math.abs(lngN) : spec.lng}°W`;
      headInner.appendChild(h3);
      headInner.appendChild(coords);
      head.appendChild(headInner);
      card.appendChild(head);

      const status = document.createElement('p');
      status.className = 'text-sm text-gray-600 js-status dark:text-gray-500';
      status.setAttribute('aria-live', 'polite');
      status.textContent = 'Cargando pronóstico...';
      card.appendChild(status);

      const weather = document.createElement('div');
      weather.className = 'space-y-1 hidden js-weather';
      const temps = document.createElement('p');
      temps.className = 'text-2xl font-bold text-gray-900 dark:text-white';
      const tmax = document.createElement('span');
      tmax.className = 'js-tmax';
      tmax.textContent = '--';
      const tmin = document.createElement('span');
      tmin.className = 'js-tmin';
      tmin.textContent = '--';
      temps.append(tmax, document.createTextNode('° / '), tmin, document.createTextNode('°C'));
      const cond = document.createElement('p');
      cond.className = 'text-sm text-gray-600 js-condition dark:text-gray-400';
      cond.textContent = '—';
      const rainP = document.createElement('p');
      rainP.className = 'text-sm text-blue-600 dark:text-blue-400';
      const rainS = document.createElement('span');
      rainS.className = 'js-rain';
      rainS.textContent = '--';
      rainP.append(document.createTextNode('💧 '), rainS, document.createTextNode('% lluvia'));
      weather.append(temps, cond, rainP);
      card.appendChild(weather);

      const peekBtn = document.createElement('button');
      peekBtn.type = 'button';
      peekBtn.className =
        'js-peek text-xs text-blue-600 hover:text-blue-700 mt-1 text-left dark:text-blue-400 dark:hover:text-blue-300';
      peekBtn.textContent = `▾ ${t.quick_peek}`;
      card.appendChild(peekBtn);

      const peekBox = document.createElement('div');
      peekBox.className =
        'js-peekbox hidden mt-2 text-xs text-gray-700 space-y-1 dark:text-gray-300';
      card.appendChild(peekBox);

      const full = document.createElement('a');
      full.className =
        'js-full inline-block mt-2 text-xs text-blue-600 border border-blue-200 rounded px-2 py-1 dark:text-blue-400 dark:border-blue-900';
      full.href = fullHref(spec.lat, spec.lng, tz, spec.name, spec.admin);
      full.textContent = `${t.full_forecast} →`;
      card.appendChild(full);

      // Per-card peek toggle.
      peekBtn.addEventListener('click', () => {
        const hidden = peekBox.classList.toggle('hidden');
        if (!hidden) fillPeek(card);
      });

      return card;
    }

    async function refreshCityCard(
      card: Element,
      loc: { lat: string; lng: string; tz: string },
    ): Promise<boolean> {
      if (!loc.lat || !loc.lng) return false;
      try {
        const f = await getForecast(
          { lat: +loc.lat, lng: +loc.lng, tz: loc.tz || 'America/Mexico_City' },
          {
            fetch: window.fetch.bind(window),
            // Show an accurate "retrying" message before each backoff wait.
            sleep: (ms: number) =>
              new Promise<void>((resolve) => {
                renderRetrying(card);
                window.setTimeout(resolve, ms);
              }),
          },
        );
        const day = f.daily[0];
        renderSuccess(card, {
          tmax: day?.tmax ?? null,
          tmin: day?.tmin ?? null,
          rain: day?.precipProbabilityMax ?? 0,
          condition: f.current.condition,
          peek: {
            windSpeed: f.current.windSpeed,
            windDir: f.current.windDir,
            uvIndex: f.current.uvIndex,
            cloudCover: f.current.cloudCover,
            humidity: f.current.humidity,
          },
        });
        return true;
      } catch {
        // All retry attempts exhausted.
        renderTerminalError(card);
        return false;
      }
    }

    function cardLoc(card: Element): { lat: string; lng: string; tz: string } {
      return {
        lat: card.getAttribute('data-lat') || '',
        lng: card.getAttribute('data-lng') || '',
        tz: card.getAttribute('data-tz') || 'America/Mexico_City',
      };
    }

    // ---- Presets: built from the same factory as favorites ------------
    interface PresetCity {
      name: string;
      emoji: string;
      lat: number;
      lng: number;
      tz: string;
    }

    function readPresetCities(): PresetCity[] {
      try {
        const el = document.getElementById('preset-data');
        return el ? JSON.parse(el.textContent || '[]') : [];
      } catch {
        return [];
      }
    }
    const presetCities: PresetCity[] = readPresetCities();

    const presetGrid = document.getElementById('preset-grid');
    const presetCards: HTMLElement[] = [];
    if (presetGrid) {
      presetCities.forEach((c) => {
        const card = buildCityCardElement({
          lat: String(c.lat),
          lng: String(c.lng),
          name: c.name,
          tz: c.tz,
        });
        presetGrid.appendChild(card);
        presetCards.push(card);
      });
    }

    // Favorite card elements currently in the DOM. Kept parallel to
    // presetCards so the interval can refresh them too. Rebuilt by
    // renderFavorites(); never re-fetched there beyond the one-shot.
    let favCards: HTMLElement[] = [];

    // includeFavs=false on the very first call: favorites were already
    // fetched once by renderFavorites(), so skipping them here avoids a
    // double initial fetch. The interval passes true so favorite cards
    // stay live alongside presets.
    async function refreshAll(includeFavs = true) {
      const cards = includeFavs
        ? presetCards.concat(favCards)
        : presetCards;
      const results = await Promise.all(
        cards.map((card) => refreshCityCard(card, cardLoc(card))),
      );
      // Only stamp a fresh timestamp when at least one card succeeded this
      // cycle; during a total outage show an accurate failure message instead.
      if (results.some((ok) => ok)) {
        setUpdatedAtMessage();
      } else {
        setUpdateFailedMessage();
      }
    }

    // ---- Favorites: "Tus lugares" -------------------------------------
    const store = window.localStorage;
    const favSection = document.getElementById('fav-section');
    const favGrid = document.getElementById('fav-grid');
    const favMsg = document.getElementById('fav-msg');

    function favFromCard(card: Element): Favorite {
      const h3 = card.querySelector('h3');
      const name = h3 ? (h3.textContent || '').trim() : '';
      const lat = Number(card.getAttribute('data-lat'));
      const lng = Number(card.getAttribute('data-lng'));
      const admin = card.getAttribute('data-admin') || undefined;
      const tz = card.getAttribute('data-tz') || undefined;
      return {
        lat,
        lng,
        name: name || `${lat},${lng}`,
        admin,
        tz,
        addedAt: Date.now(),
      };
    }

    function syncStar(btn: Element, lat: number, lng: number): void {
      const on = has(store, lat, lng);
      btn.textContent = on ? '★' : '☆';
      btn.classList.toggle('text-amber-400', on);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      const label = on ? 'Quitar de favoritos' : 'Agregar a favoritos';
      btn.setAttribute('aria-label', label);
      btn.setAttribute('title', label);
    }

    function syncAllStars(): void {
      document.querySelectorAll('.js-fav-star').forEach((btn) => {
        const card = btn.closest('[data-lat]');
        if (!card) return;
        syncStar(
          btn,
          Number(card.getAttribute('data-lat')),
          Number(card.getAttribute('data-lng')),
        );
      });
    }

    function wireStar(btn: Element): void {
      btn.addEventListener('click', () => {
        const card = btn.closest('[data-lat]');
        if (!card) return;
        const fav = favFromCard(card);
        const wasFav = has(store, fav.lat, fav.lng);
        const nowOn = toggle(store, fav);
        if (!wasFav && !nowOn) {
          // Cap reached: surface a brief non-blocking note.
          if (favMsg) favMsg.textContent = 'Máximo 12 lugares — quita uno';
        } else if (favMsg) {
          favMsg.textContent = '';
        }
        renderFavorites();
        syncAllStars();
      });
    }

    function renderFavorites(): void {
      if (!favSection || !favGrid) return;
      const favs = list(store);
      favGrid.textContent = '';
      favCards = [];
      if (favs.length === 0) {
        favSection.classList.add('hidden');
        return;
      }
      favSection.classList.remove('hidden');
      favs.forEach((f) => {
        const card = buildCityCardElement({
          lat: String(f.lat),
          lng: String(f.lng),
          name: f.name,
          tz: f.tz || 'America/Mexico_City',
          admin: f.admin,
        });
        // Remove (✕) button: toggles the favorite off and re-renders.
        const rm = document.createElement('button');
        rm.type = 'button';
        rm.className =
          'absolute top-2 right-9 text-lg leading-none text-gray-400 hover:text-red-500 dark:text-gray-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-500 rounded';
        rm.setAttribute('aria-label', 'Quitar de favoritos');
        rm.title = 'Quitar de favoritos';
        rm.textContent = '✕';
        rm.addEventListener('click', () => {
          remove(store, f.lat, f.lng);
          if (favMsg) favMsg.textContent = '';
          renderFavorites();
          syncAllStars();
        });
        card.appendChild(rm);

        const star = card.querySelector('.js-fav-star');
        if (star) wireStar(star);

        favGrid.appendChild(card);
        favCards.push(card);
        void refreshCityCard(card, cardLoc(card));
      });
      syncAllStars();
    }

    // Wire stars on the preset cards and do the initial favorites render.
    presetCards.forEach((card) => {
      const star = card.querySelector('.js-fav-star');
      if (star) wireStar(star);
    });
    renderFavorites();

    // ---- Geocoding autocomplete combobox ----
    const qInput = document.getElementById('q') as HTMLInputElement | null;
    const acList = document.getElementById('ac') as HTMLUListElement | null;
    const qMsg = document.getElementById('qmsg') as HTMLParagraphElement | null;
    const geoBtn = document.getElementById('geo') as HTMLButtonElement | null;

    type GeoItem = {
      name: string;
      admin1?: string;
      country?: string;
      lat: number;
      lng: number;
      tz: string;
      population?: number;
      featureCode?: string;
    };

    let results: GeoItem[] = [];
    let active = -1;
    let debounceId = 0;
    let searchGen = 0;

    function showMsg(text: string) {
      if (!qMsg) return;
      qMsg.textContent = text;
      qMsg.classList.remove('hidden');
    }

    function hideMsg() {
      if (!qMsg) return;
      qMsg.textContent = '';
      qMsg.classList.add('hidden');
    }

    function closeList() {
      if (!acList || !qInput) return;
      acList.classList.add('hidden');
      acList.textContent = '';
      qInput.setAttribute('aria-expanded', 'false');
      qInput.removeAttribute('aria-activedescendant');
      results = [];
      active = -1;
    }

    function highlight() {
      if (!acList || !qInput) return;
      Array.from(acList.children).forEach((li, i) => {
        if (i === active) {
          li.classList.add('bg-gray-100', 'dark:bg-gray-800');
          li.setAttribute('aria-selected', 'true');
          qInput.setAttribute('aria-activedescendant', li.id);
        } else {
          li.classList.remove('bg-gray-100', 'dark:bg-gray-800');
          li.setAttribute('aria-selected', 'false');
        }
      });
      if (active < 0) qInput.removeAttribute('aria-activedescendant');
    }

    function go(r: GeoItem) {
      location.href = fullHref(
        String(r.lat),
        String(r.lng),
        r.tz,
        r.name,
        r.admin1,
      );
    }

    function renderList() {
      if (!acList || !qInput) return;
      acList.textContent = '';
      results.forEach((r, i) => {
        const li = document.createElement('li');
        li.id = 'ac-' + i;
        li.setAttribute('role', 'option');
        li.setAttribute('aria-selected', 'false');
        li.className =
          'px-3 py-2 text-sm cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-800';

        // Primary line: city name in bold, optional "ciudad" marker for
        // populous places so the real city stands out from tiny hamlets.
        const primary = document.createElement('div');
        primary.className = 'flex items-center gap-2';

        const nameEl = document.createElement('span');
        nameEl.className = 'font-semibold text-gray-900 dark:text-gray-100';
        nameEl.textContent = r.name;
        primary.appendChild(nameEl);

        if (typeof r.population === 'number' && r.population >= 50000) {
          const badge = document.createElement('span');
          badge.className =
            'rounded-full bg-blue-500/10 px-1.5 py-0.5 text-[10px] font-medium text-blue-600 dark:text-blue-400';
          badge.textContent = 'ciudad';
          primary.appendChild(badge);
        }
        li.appendChild(primary);

        // Secondary line: "admin1 · country" muted.
        const sub = [r.admin1, r.country].filter(Boolean).join(' · ');
        if (sub) {
          const subEl = document.createElement('div');
          subEl.className = 'text-xs text-gray-500 dark:text-gray-400';
          subEl.textContent = sub;
          li.appendChild(subEl);
        }

        li.addEventListener('click', () => go(r));
        acList.appendChild(li);
      });
      acList.classList.remove('hidden');
      qInput.setAttribute('aria-expanded', 'true');
      active = -1;
    }

    async function runSearch(term: string) {
      const gen = ++searchGen;
      try {
        const res = await geocode(term, deps);
        if (gen !== searchGen) return;
        if (!res.length) {
          closeList();
          showMsg(`${t.no_results} «${term}»`);
          return;
        }
        results = res;
        hideMsg();
        renderList();
      } catch {
        if (gen !== searchGen) return;
        closeList();
        showMsg(`${t.no_results} «${term}»`);
      }
    }

    if (qInput) {
      qInput.addEventListener('input', () => {
        const term = qInput.value.trim();
        window.clearTimeout(debounceId);
        if (term === '') {
          hideMsg();
          closeList();
          return;
        }
        debounceId = window.setTimeout(() => runSearch(term), 300);
      });

      qInput.addEventListener('keydown', (e: KeyboardEvent) => {
        if (results.length === 0) {
          if (e.key === 'Escape') closeList();
          return;
        }
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          active = (active + 1) % results.length;
          highlight();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          active = active <= 0 ? results.length - 1 : active - 1;
          highlight();
        } else if (e.key === 'Enter') {
          if (active >= 0 && active < results.length) {
            e.preventDefault();
            go(results[active]);
          }
        } else if (e.key === 'Escape') {
          closeList();
        }
      });
    }

    // Click-outside closes the suggestion list.
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (
        qInput &&
        acList &&
        !qInput.contains(target) &&
        !acList.contains(target)
      ) {
        closeList();
      }
    });

    // ---- Use my location ----
    if (geoBtn) {
      geoBtn.addEventListener('click', () => {
        if (!navigator.geolocation) {
          showMsg(t.geo_denied);
          return;
        }
        showMsg(t.searching);
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            location.href = fullHref(
              String(pos.coords.latitude),
              String(pos.coords.longitude),
              'auto',
              'Tu ubicación',
            );
          },
          () => {
            showMsg(t.geo_denied);
          },
          { timeout: 10000 },
        );
      });
    }

    // Initial pass: presets only (favorites already fetched once by
    // renderFavorites). The interval then refreshes presets + favCards.
    refreshAll(false);
    window.setInterval(() => refreshAll(true), REFRESH_INTERVAL_MS);
  </script>
</BaseLayout>
