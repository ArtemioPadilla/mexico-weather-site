---
/**
 * SMN avisos widget. Renders any SMN alerts/notices that apply to a
 * location, plus the national bucket.
 *
 * Pass any of:
 *   - `stateSlug`  — single state, known at build time
 *   - `stateSlugs` — multiple states (volcanoes straddle 2–3 states)
 *   - `coords`     — resolved at runtime via point-in-polygon
 *                    (for /forecast, favorites, geolocation)
 *
 * When none of these is passed, the runtime script falls back to URL
 * params (?lat=&lng=) — used by /forecast.
 *
 * The widget always renders, including when there are zero avisos
 * (shows a calm "Sin alertas vigentes" line) — users get explicit
 * confirmation we checked. Staleness is surfaced when the index is
 * more than 6 hours old. Overflow beyond 5 items collapses to "+N
 * más" linking to /rss.xml.
 */
import { siteBase } from '../utils/paths';

interface Props {
  stateSlug?: string;
  stateSlugs?: readonly string[];
  coords?: { lat: number; lng: number };
}

const { stateSlug, stateSlugs, coords } = Astro.props;
const base = siteBase();
// Resolved mode: 'slugs' = known at build time. 'coords' = polygon
// lookup at runtime (also the URL-params fallback path).
const slugs = stateSlugs ?? (stateSlug ? [stateSlug] : []);
const mode = slugs.length > 0 ? 'slugs' : 'coords';
---

<section
  data-smn-avisos
  data-mode={mode}
  data-slugs={slugs.join(',')}
  data-lat={coords?.lat ?? ''}
  data-lng={coords?.lng ?? ''}
  data-base={base}
  aria-labelledby="smn-h"
  class="hidden rounded-lg border p-4"
  data-smn-state="loading"
>
  <h2
    id="smn-h"
    class="flex items-center gap-2 text-base font-semibold"
    data-smn-title
  >
    <span data-smn-icon aria-hidden="true">⚠️</span>
    <span data-smn-heading data-i18n-en="SMN alerts">Alertas SMN</span>
  </h2>
  <p data-smn-loc class="mt-0.5 text-xs"></p>
  <ul data-smn-list class="mt-3 space-y-2"></ul>
  <p data-smn-overflow class="mt-2 hidden text-xs"></p>
  <p class="mt-3 flex flex-wrap items-center gap-x-2 text-xs">
    <span data-smn-stale class="hidden"></span>
    <span>
      <span data-i18n-en="Source:">Fuente:</span>{' '}
      <a
        href="https://smn.conagua.gob.mx/es/"
        target="_blank"
        rel="noopener noreferrer"
        class="underline"
        data-i18n-en="Mexican National Weather Service (Conagua)"
      >
        Servicio Meteorológico Nacional (Conagua)
      </a>
    </span>
  </p>
</section>

<script>
  import {
    avisosForStates,
    loadSmnAvisos,
    type SmnAviso,
    type SmnByStateDoc,
  } from '../lib/smn-avisos';
  import { resolveStateByCoords } from '../lib/state-by-coords';
  import { findStateBySlug } from '../lib/mx-states';

  const MAX_VISIBLE = 5;
  /** Anything older than this triggers the staleness banner. The
   *  smn-rss workflow runs hourly so 6 h covers ~5 missed cron firings
   *  before users start seeing a warning. */
  const STALE_AFTER_MS = 6 * 60 * 60 * 1000;

  const lang = (document.documentElement.getAttribute('data-lang') === 'en'
    ? 'en'
    : 'es') as 'es' | 'en';

  function fmtPubDate(s: string): string {
    try {
      const d = new Date(s);
      if (Number.isNaN(d.getTime())) return s;
      return d.toLocaleString(lang === 'en' ? 'en-US' : 'es-MX', {
        day: 'numeric',
        month: 'short',
        hour: '2-digit',
        minute: '2-digit',
      });
    } catch {
      return s;
    }
  }

  function relativeAge(iso: string): string {
    const t = Date.parse(iso);
    if (!Number.isFinite(t)) return '';
    const ageMs = Date.now() - t;
    if (ageMs < 0) return '';
    const m = Math.round(ageMs / 60000);
    const ago = lang === 'en' ? '' : 'hace ';
    const agoSuffix = lang === 'en' ? ' ago' : '';
    if (m < 60) return `${ago}${m} min${agoSuffix}`;
    const h = Math.round(m / 60);
    if (h < 24) return `${ago}${h} h${agoSuffix}`;
    const d = Math.round(h / 24);
    return `${ago}${d} ${lang === 'en' ? 'd' : 'd'}${agoSuffix}`;
  }

  function severityClass(sev: SmnAviso['severity']): string {
    if (sev === 'critical')
      return 'border-red-300 bg-red-50 dark:border-red-900 dark:bg-red-950';
    if (sev === 'warn')
      return 'border-amber-300 bg-white dark:border-amber-900 dark:bg-amber-900/30';
    return 'border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900';
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  /** Toggle the host element between three visual states:
   *   loading → (transient, never rendered)
   *   alert   → amber/red callout with avisos
   *   calm    → gray, low-key, says "Sin alertas vigentes" */
  function applyVisualState(host: HTMLElement, state: 'alert' | 'calm'): void {
    host.dataset.smnState = state;
    const heading = host.querySelector('[data-smn-heading]') as HTMLElement | null;
    const icon = host.querySelector('[data-smn-icon]') as HTMLElement | null;
    host.classList.remove(
      'border-amber-200', 'bg-amber-50', 'dark:border-amber-900', 'dark:bg-amber-950',
      'border-gray-200', 'bg-gray-50', 'dark:border-gray-800', 'dark:bg-gray-900/40',
    );
    const title = host.querySelector('[data-smn-title]') as HTMLElement | null;
    const loc = host.querySelector('[data-smn-loc]') as HTMLElement | null;
    const stale = host.querySelector('[data-smn-stale]') as HTMLElement | null;
    if (state === 'alert') {
      host.classList.add('border-amber-200', 'bg-amber-50', 'dark:border-amber-900', 'dark:bg-amber-950');
      if (title) title.className = 'flex items-center gap-2 text-base font-semibold text-amber-900 dark:text-amber-200';
      if (loc) loc.className = 'mt-0.5 text-xs text-amber-800 dark:text-amber-300';
      if (stale) stale.className = stale.classList.contains('hidden')
        ? 'hidden'
        : 'text-amber-800 dark:text-amber-300';
      if (icon) icon.textContent = '⚠️';
      if (heading)
        heading.textContent = lang === 'en' ? 'SMN alerts' : 'Alertas SMN';
    } else {
      host.classList.add('border-gray-200', 'bg-gray-50', 'dark:border-gray-800', 'dark:bg-gray-900/40');
      if (title) title.className = 'flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300';
      if (loc) loc.className = 'mt-0.5 text-xs text-gray-600 dark:text-gray-400';
      if (stale) stale.className = stale.classList.contains('hidden')
        ? 'hidden'
        : 'text-gray-600 dark:text-gray-400';
      if (icon) icon.textContent = '✓';
      if (heading)
        heading.textContent = lang === 'en'
          ? 'No active SMN alerts'
          : 'Sin alertas SMN vigentes';
    }
  }

  function render(
    host: HTMLElement,
    avisos: SmnAviso[],
    locLabel: string,
    doc: SmnByStateDoc,
  ): void {
    const list = host.querySelector('[data-smn-list]') as HTMLUListElement | null;
    const locEl = host.querySelector('[data-smn-loc]') as HTMLElement | null;
    const overflowEl = host.querySelector('[data-smn-overflow]') as HTMLElement | null;
    const staleEl = host.querySelector('[data-smn-stale]') as HTMLElement | null;
    if (!list) return;

    applyVisualState(host, avisos.length === 0 ? 'calm' : 'alert');
    host.classList.remove('hidden');

    if (locEl) locEl.textContent = locLabel;

    list.innerHTML = avisos
      .slice(0, MAX_VISIBLE)
      .map(
        (a) => `
        <li class="rounded-md border p-3 text-sm ${severityClass(a.severity)}">
          <a href="${escapeHtml(a.link)}" target="_blank" rel="noopener noreferrer" class="block font-medium text-gray-900 hover:underline dark:text-gray-100">
            ${escapeHtml(a.title)}
          </a>
          <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
            ${escapeHtml(a.category || 'SMN')} · ${escapeHtml(fmtPubDate(a.pubDate))}
          </p>
        </li>
      `,
      )
      .join('');

    // Overflow notice when there are more avisos than we show. Links
    // back to /rss.xml where the full feed lives.
    if (overflowEl) {
      const hidden = Math.max(0, avisos.length - MAX_VISIBLE);
      if (hidden > 0) {
        const baseAttr = host.dataset.base || '/';
        const moreLabel = lang === 'en'
          ? `+${hidden} more aviso${hidden === 1 ? '' : 's'} in the RSS feed`
          : `+${hidden} aviso${hidden === 1 ? '' : 's'} más en el feed RSS`;
        overflowEl.innerHTML = `<a href="${escapeHtml(baseAttr)}rss.xml" class="underline">${escapeHtml(moreLabel)}</a>`;
        overflowEl.classList.remove('hidden');
      } else {
        overflowEl.classList.add('hidden');
      }
    }

    // Staleness — show 'Actualizado hace X' when older than threshold.
    if (staleEl) {
      const upd = doc.metadata?.updated;
      const age = upd ? Date.parse(upd) : NaN;
      const ageMs = Number.isFinite(age) ? Date.now() - age : NaN;
      if (Number.isFinite(ageMs) && ageMs > STALE_AFTER_MS) {
        const prefix = lang === 'en' ? 'Updated' : 'Actualizado';
        staleEl.textContent = `${prefix} ${relativeAge(upd!)} ·`;
        staleEl.classList.remove('hidden');
      } else {
        staleEl.classList.add('hidden');
      }
    }
  }

  async function init(host: HTMLElement): Promise<void> {
    const mode = host.dataset.mode;
    const base = host.dataset.base || '/';
    const doc = await loadSmnAvisos(base);
    if (!doc) {
      // No SMN data available at all — hide entirely. Distinct from
      // 'no avisos' (which renders the calm state).
      host.classList.add('hidden');
      return;
    }

    let resolvedSlugs: string[] = [];
    if (mode === 'slugs') {
      const raw = host.dataset.slugs || '';
      resolvedSlugs = raw.split(',').map((s) => s.trim()).filter(Boolean);
    } else {
      let lat = Number(host.dataset.lat);
      let lng = Number(host.dataset.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
        // /forecast and similar pages get coords from URL params.
        const params = new URLSearchParams(window.location.search);
        const latS = params.get('lat');
        const lngS = params.get('lng');
        if (latS && lngS) {
          lat = Number(latS);
          lng = Number(lngS);
        }
      }
      if (Number.isFinite(lat) && Number.isFinite(lng)) {
        const slug = await resolveStateByCoords(lat, lng, base);
        if (slug) resolvedSlugs = [slug];
      }
    }

    const avisos = avisosForStates(doc, resolvedSlugs);
    const stateNames = resolvedSlugs
      .map((s) => findStateBySlug(s)?.name)
      .filter((n): n is string => Boolean(n));
    let label: string;
    if (stateNames.length === 0) {
      label = avisos.length === 0
        ? lang === 'en'
          ? 'No active national alerts.'
          : 'Sin avisos nacionales activos.'
        : lang === 'en'
          ? 'Active national alerts:'
          : 'Avisos nacionales vigentes:';
    } else {
      const conj = lang === 'en' ? ' and ' : ' y ';
      const list =
        stateNames.length === 1
          ? stateNames[0]
          : stateNames.slice(0, -1).join(', ') + conj + stateNames.slice(-1);
      if (lang === 'en') {
        label = avisos.length === 0
          ? `No active alerts for ${list}.`
          : `${stateNames.length === 1 ? 'Affected state' : 'Affected states'}: ${list}. Active alerts:`;
      } else {
        label = avisos.length === 0
          ? `Sin avisos vigentes para ${list}.`
          : `${stateNames.length === 1 ? 'Estado afectado' : 'Estados afectados'}: ${list}. Avisos vigentes:`;
      }
    }
    render(host, avisos, label, doc);
  }

  document
    .querySelectorAll<HTMLElement>('[data-smn-avisos]')
    .forEach((el) => void init(el));
</script>
