---
/**
 * Marine panel (wave height + sea-surface temperature).
 *
 * Pass `beachName` for /playa/<slug>/ (direct lookup) or `coords`
 * (or nothing — runtime URL params) for /forecast/ which then finds
 * the nearest TOP_BEACHES within 15 km. Hidden inland.
 */
import { siteBase } from '../utils/paths';

interface Props {
  beachName?: string;
  coords?: { lat: number; lng: number };
}

const { beachName, coords } = Astro.props;
const base = siteBase();
---

<section
  data-marine-panel
  data-beach={beachName ?? ''}
  data-lat={coords?.lat ?? ''}
  data-lng={coords?.lng ?? ''}
  data-base={base}
  aria-labelledby="marine-panel-h"
  class="hidden rounded-lg border border-gray-200 bg-gradient-to-br from-cyan-50 to-blue-50 p-5 dark:border-gray-800 dark:from-gray-900 dark:to-gray-900"
>
  <h2 id="marine-panel-h" class="flex items-center gap-2 text-base font-semibold">
    <span aria-hidden="true">🌊</span>
    <span>Mar en la costa</span>
    <span
      data-marine-loc
      class="ml-auto text-xs font-normal text-gray-600 dark:text-gray-400"
    ></span>
  </h2>
  <div class="mt-3 grid gap-4 sm:grid-cols-2">
    <div>
      <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
        Altura de las olas
      </p>
      <p class="mt-1">
        <span data-marine-wave class="text-2xl font-bold tabular-nums">—</span>
        <span class="text-sm text-gray-500 dark:text-gray-400">m</span>
      </p>
      <p data-marine-wave-label class="text-sm text-gray-600 dark:text-gray-400">—</p>
    </div>
    <div>
      <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
        Temperatura del mar
      </p>
      <p class="mt-1">
        <span data-marine-sst class="text-2xl font-bold tabular-nums">—</span>
        <span class="text-sm text-gray-500 dark:text-gray-400">°C</span>
      </p>
      <p data-marine-sst-label class="text-sm text-gray-600 dark:text-gray-400">—</p>
    </div>
  </div>
</section>

<script>
  import {
    findMarineByName,
    findNearestMarine,
    sstLabel,
    waveLabel,
  } from '../lib/marine';

  async function init(host: HTMLElement): Promise<void> {
    const base = host.dataset.base || '/';
    const beachName = host.dataset.beach;

    let reading;
    if (beachName) {
      reading = await findMarineByName(beachName, base);
    } else {
      // Coords prop OR URL params (for /forecast).
      let lat = Number(host.dataset.lat);
      let lng = Number(host.dataset.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
        const params = new URLSearchParams(window.location.search);
        const latS = params.get('lat');
        const lngS = params.get('lng');
        if (latS && lngS) {
          lat = Number(latS);
          lng = Number(lngS);
        }
      }
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;
      reading = await findNearestMarine(lat, lng, base);
    }
    if (!reading) return;

    const waveEl = host.querySelector('[data-marine-wave]') as HTMLElement | null;
    const waveLblEl = host.querySelector('[data-marine-wave-label]') as HTMLElement | null;
    const sstEl = host.querySelector('[data-marine-sst]') as HTMLElement | null;
    const sstLblEl = host.querySelector('[data-marine-sst-label]') as HTMLElement | null;
    const locEl = host.querySelector('[data-marine-loc]') as HTMLElement | null;

    if (waveEl) waveEl.textContent = reading.hs === null ? '—' : reading.hs.toFixed(1);
    if (waveLblEl)
      waveLblEl.textContent = reading.hs === null ? '—' : waveLabel(reading.hs);
    if (sstEl) sstEl.textContent = reading.sst === null ? '—' : String(reading.sst);
    if (sstLblEl)
      sstLblEl.textContent = reading.sst === null ? '—' : sstLabel(reading.sst);
    if (locEl && reading.distanceKm > 0) {
      const km = Math.round(reading.distanceKm);
      locEl.textContent = `Estación: ${reading.beachName} (${km} km)`;
    } else if (locEl) {
      locEl.textContent = reading.beachName;
    }

    host.classList.remove('hidden');
  }

  document
    .querySelectorAll<HTMLElement>('[data-marine-panel]')
    .forEach((el) => void init(el));
</script>
