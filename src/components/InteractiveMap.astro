---
/**
 * InteractiveMap — Reusable wrapper around the full MapLibre experience
 * (basemap, search, layer rail, opacity slider, legend, timeline,
 * preset/user pins, dark-mode swap, terminator overlay, etc.).
 *
 * Used by:
 *   /mapa      — full-screen (all features on)
 *   /          — 400px embed (layer rail + timeline + preset pins)
 *   /forecast  — 320px embed (basemap only; pin + popup)
 *
 * Each instance owns a uniquely-prefixed set of IDs (mapId="map" stays
 * stable for /mapa to preserve e2e selectors and the ?e2e=1 affordance).
 */
import { ui } from '../i18n/ui';

interface Features {
  layerRail?: boolean;
  timeline?: boolean;
  search?: boolean;
  locateButton?: boolean;
  presetPins?: boolean;
  backLink?: boolean;
}

interface Props {
  /** Unique DOM id for the map container; the rest of the IDs are
   *  derived from this so two instances on one page don't collide.
   *  Use "map" for /mapa to preserve e2e selectors. */
  mapId?: string;
  /** Container height (CSS length, e.g. "100vh" or "400px"). */
  height?: string;
  initialView?: { lat: number; lng: number; zoom: number };
  /** Layer to activate on first load. Defaults to 'base'.
   *  Set to 'temperature' on the forecast embed so the user sees weather
   *  data near their location without an extra click. */
  initialLayer?: string;
  features?: Features;
  /** When true, parses + writes location.hash. Only /mapa should set this. */
  useHash?: boolean;
  /** When true, exposes window.__map under ?e2e=1. Only /mapa should set this. */
  exposeE2eHook?: boolean;
  /** When false, the map is non-interactive. Defaults true. */
  interactive?: boolean;
  /** When false, no marker popup. Defaults true. */
  markerPopups?: boolean;
  /** When true, an IntersectionObserver defers the maplibre dynamic import
   *  until the map is in viewport. Defaults true for embeds; off for /mapa. */
  lazy?: boolean;
  /** Tailwind classes for the outer wrapper. */
  class?: string;
  lang?: 'es' | 'en';
}

const {
  mapId = 'map',
  height = '100vh',
  initialView = { lat: 23.6, lng: -102.5, zoom: 4.5 },
  initialLayer,
  features = {
    layerRail: true,
    timeline: true,
    search: true,
    locateButton: true,
    presetPins: true,
    backLink: true,
  },
  useHash = false,
  exposeE2eHook = false,
  interactive = true,
  markerPopups = true,
  lazy = true,
  class: className = '',
  lang = 'es' as const,
} = Astro.props;

const t = ui[lang];
const base = import.meta.env.BASE_URL;

// Derived IDs — let two instances coexist on one page.
const ids = {
  root: `${mapId}-root`,
  q: mapId === 'map' ? 'mapq' : `${mapId}-q`,
  ac: mapId === 'map' ? 'mapac' : `${mapId}-ac`,
  loc: mapId === 'map' ? 'maploc' : `${mapId}-loc`,
  layerBtns: mapId === 'map' ? 'layerbtns' : `${mapId}-layerbtns`,
  overlayBtns: mapId === 'map' ? 'layerbtns-overlays' : `${mapId}-layerbtns-overlays`,
  opacityWrap: mapId === 'map' ? 'opacitywrap' : `${mapId}-opacitywrap`,
  opacity: mapId === 'map' ? 'opacity' : `${mapId}-opacity`,
  legend: mapId === 'map' ? 'legend' : `${mapId}-legend`,
  msg: mapId === 'map' ? 'mapmsg' : `${mapId}-msg`,
  tooltip: mapId === 'map' ? 'mapTooltip' : `${mapId}-tooltip`,
  coords: mapId === 'map' ? 'mapCoords' : `${mapId}-coords`,
  timeline: mapId === 'map' ? 'timeline' : `${mapId}-timeline`,
  tlPrev: mapId === 'map' ? 'tl-prev' : `${mapId}-tl-prev`,
  tlPlay: mapId === 'map' ? 'tl-play' : `${mapId}-tl-play`,
  tlNext: mapId === 'map' ? 'tl-next' : `${mapId}-tl-next`,
  tlRange: mapId === 'map' ? 'tl-range' : `${mapId}-tl-range`,
  tlTime: mapId === 'map' ? 'tl-time' : `${mapId}-tl-time`,
};

// Serialise config for the inline bootstrap script.
const cfg = JSON.stringify({
  mapId,
  ids,
  initialView,
  initialLayer,
  features,
  useHash,
  exposeE2eHook,
  interactive,
  markerPopups,
  lazy,
  lang,
});
---

<div
  id={ids.root}
  class:list={[
    'im-root relative w-full overflow-hidden bg-gray-100 dark:bg-gray-950',
    className,
  ]}
  style={`height:${height};`}
  data-im-config={cfg}
>
  {features.backLink && (
    <a
      href={base}
      class="absolute left-3 top-3 z-10 rounded-lg bg-white/90 px-3 py-1.5 text-sm text-blue-600 shadow hover:underline dark:bg-gray-900/90 dark:text-blue-400"
      >← {t.back_home}</a
    >
  )}
  {/* Snapshot compare overlay (plan 3.3). Holds the captured canvas
      as an <img> stretched to the map. Hidden until populated. */}
  <img
    id="mw-snapshot-img"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute left-0 top-0 z-[5] hidden h-full w-full opacity-50 mix-blend-multiply dark:mix-blend-screen"
  />

  {features.search && (
    <div class="absolute right-3 top-3 z-10 flex w-80 max-w-[calc(100vw-1.5rem)] flex-col items-end gap-2">
      <div class="flex w-full gap-2">
        <input
          id={ids.q}
          type="text"
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls={ids.ac}
          aria-autocomplete="list"
          aria-label={t.map_search_placeholder}
          placeholder={t.map_search_placeholder}
          class="flex-1 rounded-lg border border-gray-300 bg-white/95 px-3 py-1.5 text-sm text-gray-900 shadow focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900/95 dark:text-gray-100"
        />
        {features.locateButton && (
          <button
            id={ids.loc}
            type="button"
            class="whitespace-nowrap rounded-lg border border-gray-300 bg-white/95 px-3 py-1.5 text-sm text-blue-700 shadow hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900/95 dark:text-blue-300"
            ><span aria-hidden="true">📍</span> {t.map_locate}</button
          >
        )}
      </div>
      <ul
        id={ids.ac}
        role="listbox"
        class="hidden w-full overflow-hidden rounded-lg border border-gray-300 bg-white/95 text-start shadow dark:border-gray-700 dark:bg-gray-900/95"
      ></ul>
    </div>
  )}

  {features.layerRail && (
    <div
      class="im-rail absolute left-3 top-14 z-10 w-auto sm:w-44 max-w-[calc(100vw-1.5rem)] space-y-2 rounded-lg bg-white/95 p-2 sm:p-3 text-sm shadow dark:bg-gray-900/95"
      aria-label={t.map_layers}
      role="group"
    >
      <p class="hidden sm:block font-semibold text-gray-700 dark:text-gray-200">{t.map_layers}</p>
      <div id={ids.layerBtns} class="flex flex-col gap-1"></div>
      <div id={ids.opacityWrap} class="hidden sm:block pt-1">
        <label for={ids.opacity} class="block text-xs text-gray-600 dark:text-gray-400"
          >{t.map_opacity}</label
        >
        <input
          id={ids.opacity}
          type="range"
          min="0"
          max="100"
          value="80"
          class="w-full accent-blue-600"
        />
      </div>
      {/* Legend moved out of the rail (plan P0.2) — see floating bar
          below, anchored to the map's bottom-left. We keep a hidden
          placeholder here to preserve any legacy querySelector that
          might still reference #legend inside the rail. */}

      {/* Snapshot compare buttons moved out of the layer rail (plan P2.4).
          See the floating column below — they live to the right with
          other globals, not as a "layer" choice. */}

      {/*
        Superposiciones (overlays) panel — zoom.earth-style checkboxes
        for non-exclusive map decorations. Rendered as a <details>
        accordion so the rail stays compact when not expanded.
        Hidden on mobile to keep the rail compact; keyboard shortcuts
        still toggle the overlays.
      */}
      <details class="hidden sm:block pt-2 text-xs">
        <summary class="cursor-pointer select-none font-semibold text-gray-700 dark:text-gray-200">
          Superposiciones
        </summary>
        <div id={`${ids.layerBtns}-overlays`} class="mt-2 flex flex-col gap-1"></div>
      </details>
    </div>
  )}

  <p
    id={ids.msg}
    aria-live="polite"
    class="absolute bottom-20 left-1/2 z-10 hidden -translate-x-1/2 rounded-lg bg-white/95 px-3 py-1.5 text-xs text-gray-700 shadow dark:bg-gray-900/95 dark:text-gray-300"
  >
  </p>

  {features.timeline && (
    <div
      id={ids.timeline}
      class="absolute bottom-3 left-1/2 z-30 flex -translate-x-1/2 items-center gap-1 rounded-full bg-gray-900/85 px-3 py-1.5 text-sm text-white shadow-lg backdrop-blur-sm sm:gap-2 sm:px-4"
      role="group"
      aria-label={t.timeline_label}
    >
      <button
        id={ids.tlPlay}
        type="button"
        aria-label={t.timeline_play}
        aria-pressed="false"
        disabled
        class="rounded-full bg-white/10 px-2.5 py-1 text-base leading-none hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 disabled:opacity-40"
        >▶</button
      >
      <button
        id="tl-day-prev"
        type="button"
        aria-label="Día anterior"
        title="Día anterior (-24 h)"
        class="hidden px-1.5 py-1 text-xs leading-none hover:text-blue-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 sm:inline-flex"
        >«</button
      >
      <button
        id={ids.tlPrev}
        type="button"
        aria-label={t.timeline_prev}
        title="Hora anterior"
        class="px-1.5 py-1 text-base leading-none hover:text-blue-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
        >‹</button
      >
      <span
        id={ids.tlTime}
        aria-live="polite"
        aria-atomic="true"
        class="min-w-[7rem] text-center font-medium tabular-nums sm:min-w-[8rem]"
      >—</span>
      <button
        id={ids.tlNext}
        type="button"
        aria-label={t.timeline_next}
        title="Hora siguiente"
        class="px-1.5 py-1 text-base leading-none hover:text-blue-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
        >›</button
      >
      <button
        id="tl-day-next"
        type="button"
        aria-label="Día siguiente"
        title="Día siguiente (+24 h)"
        class="hidden px-1.5 py-1 text-xs leading-none hover:text-blue-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 sm:inline-flex"
        >»</button
      >
      <button
        id="tl-now"
        type="button"
        aria-label="Volver al frame actual"
        title="Ahora"
        class="hidden rounded-full bg-white/10 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 sm:inline-flex"
        >Ahora</button
      >
      <input
        id={ids.tlRange}
        type="range"
        min="0"
        max="0"
        value="0"
        class="hidden w-40 accent-blue-500 lg:inline-block"
        aria-label={t.timeline_label}
      />
    </div>
  )}

  <div id={mapId} class="h-full w-full" role="application" aria-label={t.map_title}></div>

  {/*
    Floating tooltip that follows the cursor when a field/wind/sun layer
    is active. Hidden by default; interactive-map.ts toggles it on
    mousemove/touchmove and updates left/top + textContent in one frame.
    `pointer-events-none` so it never eats map drags; `z-50` so it sits
    above the layer rail and the timeline.
  */}
  <div
    id={ids.tooltip}
    role="status"
    aria-live="polite"
    aria-atomic="true"
    class="im-tooltip pointer-events-none absolute left-0 top-0 z-50 hidden whitespace-pre rounded bg-gray-900/85 px-2 py-1 text-sm font-medium leading-tight text-white shadow-lg backdrop-blur-sm dark:bg-gray-950/90"
    style="will-change: transform, left, top;"
  ></div>

  {/*
    Cursor coordinate badge in the bottom-left, zoom.earth-style. Hidden
    on embeds where the corner is too cramped — only the full /mapa page
    passes a non-null `coords` element to initInteractiveMap.
  */}
  {features.layerRail && (
    <div
      id={ids.coords}
      class="pointer-events-none absolute bottom-2 left-2 z-10 rounded bg-gray-900/70 px-2 py-1 text-xs font-mono tabular-nums text-gray-200 backdrop-blur-sm hidden sm:inline-block"
      aria-hidden="true"
    ></div>
  )}

  {/*
    Floating legend bar (plan P0.2) — zoom.earth-style horizontal
    color scale anchored to the bottom-left of the map area, above the
    cursor coords badge. Stays visible even when the layer rail is
    collapsed. Hidden on mobile to keep the corner uncluttered.
  */}
  {features.layerRail && (
    <div
      id="legend-bar"
      class="pointer-events-none absolute bottom-10 left-2 z-10 hidden sm:flex items-center gap-2 rounded bg-white/95 px-3 py-1.5 text-xs text-gray-700 shadow backdrop-blur-sm dark:bg-gray-900/95 dark:text-gray-200"
      aria-hidden="true"
    >
      <span id="legend-unit" class="font-semibold text-[10px] uppercase tracking-wide text-gray-500 dark:text-gray-400"></span>
      <ul id={ids.legend} class="flex items-center gap-2"></ul>
    </div>
  )}

  {/*
    Forecast model badge bottom-right, zoom.earth-style "ICON 13 km".
    Open-Meteo's bulk endpoint uses 'best_match' which selects the
    highest-resolution model per location (ECMWF in MX = ~9 km, ICON
    ~13 km global fallback). Static label; no JS needed.
  */}
  {features.layerRail && (
    <div
      id="mw-model-toggle"
      class="absolute bottom-9 right-2 z-10 hidden items-center gap-1 rounded-full bg-gray-900/80 px-1 py-0.5 text-[10px] font-mono tabular-nums text-gray-300 backdrop-blur-sm sm:inline-flex"
      aria-label="Modelo de pronóstico Open-Meteo"
    >
      {[
        { id: 'best_match', label: 'Auto' },
        { id: 'icon_seamless', label: 'ICON' },
        { id: 'gfs_seamless', label: 'GFS' },
        { id: 'ecmwf_ifs04', label: 'ECMWF' },
        { id: 'jma_seamless', label: 'JMA' },
      ].map((m) => (
        <button
          type="button"
          data-model={m.id}
          aria-pressed={m.id === 'best_match' ? 'true' : 'false'}
          class="mw-model-btn rounded-full px-1.5 py-0.5 hover:bg-white/10 aria-pressed:bg-blue-500/30 aria-pressed:text-white aria-pressed:font-semibold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
        >{m.label}</button>
      ))}
    </div>
  )}

  {/* Snapshot compare tools (plan P2.4 — moved out of the layer rail).
      Right edge column above the model toggle. */}
  {features.layerRail && (
    <div
      id="mw-snapshot-wrap"
      class="absolute bottom-20 right-2 z-10 hidden flex-col items-stretch gap-1 text-xs sm:flex"
    >
      <button
        id="mw-snapshot-capture"
        type="button"
        class="rounded-full bg-white/95 px-3 py-1 text-gray-700 shadow hover:bg-blue-500/10 dark:bg-gray-900/95 dark:text-gray-200"
        aria-label="Capturar vista actual"
        title="Capturar vista actual"
      >📸 Capturar</button>
      <button
        id="mw-snapshot-toggle"
        type="button"
        class="hidden rounded-full bg-blue-600/90 px-3 py-1 font-semibold text-white shadow hover:bg-blue-500"
        aria-pressed="true"
      >👁 Ocultar</button>
      <button
        id="mw-snapshot-clear"
        type="button"
        class="hidden rounded-full bg-white/95 px-3 py-1 text-gray-600 shadow hover:bg-red-500/10 dark:bg-gray-900/95 dark:text-gray-400"
      >✕ Limpiar</button>
    </div>
  )}

  {/*
    Settings panel (zoom.earth-style ⚙️). Timezone + hour format
    persisted in localStorage. Plain HTML <details> with inline
    onclick handlers so no extra bundle.
  */}
  {features.layerRail && (
    <details
      id="mw-settings"
      class="absolute right-3 top-12 z-10 max-w-xs rounded-lg bg-white/95 text-xs shadow dark:bg-gray-900/95"
    >
      <summary
        class="cursor-pointer select-none rounded-lg px-2 py-1.5 font-semibold text-gray-700 hover:bg-blue-500/10 dark:text-gray-200"
        aria-label="Configuración"
      >⚙️ Configuración</summary>
      <div class="space-y-3 border-t border-gray-200 px-3 py-2 text-gray-600 dark:border-gray-700 dark:text-gray-300">
        <div>
          <p class="mb-1 text-[10px] uppercase tracking-wide text-gray-500 dark:text-gray-400">Zona horaria</p>
          <div class="flex gap-1" data-mw-tz>
            <button data-val="local" class="flex-1 rounded border border-gray-300 px-2 py-1 hover:bg-blue-500/10 aria-pressed:bg-blue-500/15 aria-pressed:border-blue-500 aria-pressed:font-semibold dark:border-gray-700">Local</button>
            <button data-val="UTC" class="flex-1 rounded border border-gray-300 px-2 py-1 hover:bg-blue-500/10 aria-pressed:bg-blue-500/15 aria-pressed:border-blue-500 aria-pressed:font-semibold dark:border-gray-700">UTC</button>
          </div>
        </div>
        <div>
          <p class="mb-1 text-[10px] uppercase tracking-wide text-gray-500 dark:text-gray-400">Formato de hora</p>
          <div class="flex gap-1" data-mw-hour>
            <button data-val="12" class="flex-1 rounded border border-gray-300 px-2 py-1 hover:bg-blue-500/10 aria-pressed:bg-blue-500/15 aria-pressed:border-blue-500 aria-pressed:font-semibold dark:border-gray-700">12 h</button>
            <button data-val="24" class="flex-1 rounded border border-gray-300 px-2 py-1 hover:bg-blue-500/10 aria-pressed:bg-blue-500/15 aria-pressed:border-blue-500 aria-pressed:font-semibold dark:border-gray-700">24 h</button>
          </div>
        </div>
        <p class="text-[10px] italic text-gray-500 dark:text-gray-400">
          Aplica al reloj del timeline. Persistido localmente.
        </p>
      </div>
    </details>
  )}

  {/*
    Info panel (zoom.earth-style ℹ️). Lists data sources and credits.
    Pure HTML via <details> — no JS needed.
  */}
  {features.layerRail && (
    <details
      class="absolute right-3 top-3 z-10 max-w-xs rounded-lg bg-white/95 text-xs shadow dark:bg-gray-900/95"
    >
      <summary
        class="cursor-pointer select-none rounded-lg px-2 py-1.5 font-semibold text-gray-700 hover:bg-blue-500/10 dark:text-gray-200"
        aria-label="Información y fuentes de datos"
      >ℹ️ Fuentes</summary>
      <div class="space-y-2 border-t border-gray-200 px-3 py-2 text-gray-600 dark:border-gray-700 dark:text-gray-300">
        <p>
          <strong class="text-gray-800 dark:text-gray-100">Clima México</strong>
          — mapa interactivo del tiempo. Sin cuenta, sin cookies.
        </p>
        <ul class="space-y-1">
          <li>
            <span class="font-medium text-gray-700 dark:text-gray-200">Pronóstico:</span>
            <a class="text-blue-600 underline dark:text-blue-400" href="https://open-meteo.com/" rel="noopener" target="_blank">Open-Meteo</a>
            (ICON/GFS/ECMWF)
          </li>
          <li>
            <span class="font-medium text-gray-700 dark:text-gray-200">Radar:</span>
            <a class="text-blue-600 underline dark:text-blue-400" href="https://www.rainviewer.com/" rel="noopener" target="_blank">RainViewer</a>
          </li>
          <li>
            <span class="font-medium text-gray-700 dark:text-gray-200">Satélite:</span>
            <a class="text-blue-600 underline dark:text-blue-400" href="https://nasa-gibs.github.io/gibs-api-docs/" rel="noopener" target="_blank">NASA GIBS</a>
            (GOES-East, VIIRS)
          </li>
          <li>
            <span class="font-medium text-gray-700 dark:text-gray-200">Ciclones:</span>
            <a class="text-blue-600 underline dark:text-blue-400" href="https://www.nhc.noaa.gov/" rel="noopener" target="_blank">NOAA NHC</a>
          </li>
          <li>
            <span class="font-medium text-gray-700 dark:text-gray-200">Mapa base:</span>
            <a class="text-blue-600 underline dark:text-blue-400" href="https://www.openstreetmap.org/copyright" rel="noopener" target="_blank">OSM</a>
            / <a class="text-blue-600 underline dark:text-blue-400" href="https://carto.com/attributions" rel="noopener" target="_blank">CARTO</a>
          </li>
          <li>
            <span class="font-medium text-gray-700 dark:text-gray-200">Avisos:</span>
            <a class="text-blue-600 underline dark:text-blue-400" href="https://smn.conagua.gob.mx/" rel="noopener" target="_blank">SMN / CONAGUA</a>
          </li>
        </ul>
        <p class="pt-1 text-[10px] italic text-gray-500 dark:text-gray-400">
          Sin garantía. Para uso informativo. Consulta avisos oficiales.
        </p>
      </div>
    </details>
  )}
</div>

{/*
 * Popup contrast fix for dark mode (issue #71) — applied globally because
 * MapLibre popups portal to <body>. Same selectors as before; declared
 * here once and shared across all map instances on the page.
 */}
<style is:global>
  /*
   * Map zoom (NavigationControl) sits at bottom-left after PR #117 to dodge
   * the feedback FAB (bottom-right). On embeds (forecast 320px, home 400px)
   * the bottom-left corner is the very edge of the embed and on /mapa the
   * timeline scrubber sits at bottom-center — the +/- buttons were
   * touching / clipping the viewport edge. Bump them up so they sit clear
   * of the timeline AND have breathing room at the embed bottom.
   */
  .maplibregl-ctrl-bottom-left {
    bottom: 72px !important;
    left: 12px !important;
  }

  html.dark .maplibregl-popup-content {
    background: #111827;
    color: #f3f4f6;
  }
  html.dark .maplibregl-popup-content a {
    color: #93c5fd;
  }
  html.dark .maplibregl-popup-tip {
    border-top-color: #111827;
    border-bottom-color: #111827;
  }
  html.dark .maplibregl-popup-anchor-top .maplibregl-popup-tip,
  html.dark .maplibregl-popup-anchor-top-left .maplibregl-popup-tip,
  html.dark .maplibregl-popup-anchor-top-right .maplibregl-popup-tip {
    border-bottom-color: #111827;
    border-top-color: transparent;
  }
  html.dark .maplibregl-popup-anchor-bottom .maplibregl-popup-tip,
  html.dark .maplibregl-popup-anchor-bottom-left .maplibregl-popup-tip,
  html.dark .maplibregl-popup-anchor-bottom-right .maplibregl-popup-tip {
    border-top-color: #111827;
    border-bottom-color: transparent;
  }
  html.dark .maplibregl-popup-anchor-left .maplibregl-popup-tip {
    border-right-color: #111827;
  }
  html.dark .maplibregl-popup-anchor-right .maplibregl-popup-tip {
    border-left-color: #111827;
  }
  html.dark .maplibregl-popup-close-button {
    color: #d1d5db;
  }
</style>

<script>
  import { initInteractiveMap } from '../lib/interactive-map';

  type ImCfg = {
    mapId: string;
    ids: Record<string, string>;
    initialView: { lat: number; lng: number; zoom: number };
    initialLayer?: string;
    features: {
      layerRail?: boolean;
      timeline?: boolean;
      search?: boolean;
      locateButton?: boolean;
      presetPins?: boolean;
      backLink?: boolean;
    };
    useHash: boolean;
    exposeE2eHook: boolean;
    interactive: boolean;
    markerPopups: boolean;
    lazy: boolean;
    lang: 'es' | 'en';
  };

  // Init every map root on the page. Each root carries its own config in a
  // data-attribute so two embeds (e.g. /mapa overlay vs an embed) coexist.
  function bootAll(): void {
    const roots = document.querySelectorAll<HTMLElement>('.im-root[data-im-config]');
    roots.forEach((root) => {
      // Guard against double-init under HMR / view transitions.
      if (root.dataset.imBooted === '1') return;
      root.dataset.imBooted = '1';

      let cfg: ImCfg;
      try {
        cfg = JSON.parse(root.dataset.imConfig || '{}') as ImCfg;
      } catch {
        return;
      }

      const container = document.getElementById(cfg.mapId);
      if (!container) return;

      const boot = (): void => {
        const els = {
          container,
          search: document.getElementById(cfg.ids.q) as HTMLInputElement | null,
          acList: document.getElementById(cfg.ids.ac) as HTMLUListElement | null,
          locate: document.getElementById(cfg.ids.loc),
          layerBtns: document.getElementById(cfg.ids.layerBtns),
          overlayBtns: document.getElementById(cfg.ids.overlayBtns),
          opacityWrap: document.getElementById(cfg.ids.opacityWrap),
          opacity: document.getElementById(cfg.ids.opacity) as HTMLInputElement | null,
          legend: document.getElementById(cfg.ids.legend),
          timeline: document.getElementById(cfg.ids.timeline),
          tlPrev: document.getElementById(cfg.ids.tlPrev),
          tlPlay: document.getElementById(cfg.ids.tlPlay) as HTMLButtonElement | null,
          tlNext: document.getElementById(cfg.ids.tlNext),
          tlRange: document.getElementById(cfg.ids.tlRange) as HTMLInputElement | null,
          tlTime: document.getElementById(cfg.ids.tlTime),
          msg: document.getElementById(cfg.ids.msg),
          tooltip: document.getElementById(cfg.ids.tooltip),
          coords: document.getElementById(cfg.ids.coords),
        };
        void initInteractiveMap({
          els,
          features: cfg.features,
          initialView: cfg.initialView,
          initialLayer: cfg.initialLayer,
          useHash: cfg.useHash,
          exposeE2eHook: cfg.exposeE2eHook,
          interactive: cfg.interactive,
          markerPopups: cfg.markerPopups,
          lang: cfg.lang,
        });
      };

      if (cfg.lazy && typeof IntersectionObserver === 'function') {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                obs.disconnect();
                boot();
                return;
              }
            }
          },
          { rootMargin: '200px' },
        );
        io.observe(root);
      } else {
        // /mapa is non-lazy: the whole viewport IS the map, so boot now.
        window.requestAnimationFrame(boot);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootAll);
  } else {
    bootAll();
  }
</script>
