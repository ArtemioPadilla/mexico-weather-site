---
/**
 * PWA install prompt — listens for the browser's beforeinstallprompt
 * event and surfaces a discrete bottom-left "Instalar app" button so
 * the user can add the site to their home screen / launcher. Hidden
 * after install or dismissal; remembered in localStorage so we don't
 * pester the same user repeatedly.
 *
 * iOS Safari doesn't fire beforeinstallprompt; on iOS we show a
 * one-shot tip instead, with manual instructions ("Compartir →
 * Añadir a inicio").
 */
---

<div
  id="pwa-install-wrap"
  class="pointer-events-none fixed bottom-3 left-3 z-30 hidden"
  aria-live="polite"
>
  <button
    id="pwa-install-btn"
    type="button"
    class="pointer-events-auto inline-flex items-center gap-1.5 rounded-full bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white shadow-lg ring-2 ring-white/40 hover:bg-blue-500 dark:ring-gray-900/40"
    aria-label="Instalar Clima México como app"
  >
    <svg
      class="h-4 w-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"
      />
    </svg>
    Instalar app
  </button>
</div>

<script is:inline>
  (function () {
    var KEY = 'mw:pwa-install-dismissed';
    var wrap = document.getElementById('pwa-install-wrap');
    var btn = document.getElementById('pwa-install-btn');
    if (!wrap || !btn) return;

    function alreadyInstalled() {
      try {
        return (
          window.matchMedia('(display-mode: standalone)').matches ||
          /** @type {any} */ (window.navigator).standalone === true
        );
      } catch (e) {
        return false;
      }
    }
    function dismissed() {
      try {
        return localStorage.getItem(KEY) === '1';
      } catch (e) {
        return false;
      }
    }
    function dismiss() {
      try {
        localStorage.setItem(KEY, '1');
      } catch (e) {
        /* ignore */
      }
      wrap.classList.add('hidden');
    }

    if (alreadyInstalled() || dismissed()) return;

    var deferred = null;
    window.addEventListener('beforeinstallprompt', function (e) {
      e.preventDefault();
      deferred = e;
      wrap.classList.remove('hidden');
    });
    btn.addEventListener('click', function () {
      if (!deferred) {
        // iOS Safari path — no prompt available, show a manual tip.
        alert(
          'En iOS: toca el botón Compartir (cuadro con flecha) y elige "Añadir a inicio" para instalar Clima México como app.',
        );
        dismiss();
        return;
      }
      deferred.prompt();
      deferred.userChoice.then(function (choice) {
        if (choice && choice.outcome === 'accepted') {
          dismiss();
        }
        deferred = null;
      });
    });

    // iOS Safari fallback: surface the button anyway (manual instructions)
    // on first visit, dismissed on click.
    var isIosSafari =
      /iphone|ipad|ipod/i.test(navigator.userAgent) &&
      !/crios|fxios|edgios/i.test(navigator.userAgent);
    if (isIosSafari && !alreadyInstalled() && !dismissed()) {
      // Wait a beat so the button doesn't compete with first paint.
      setTimeout(function () {
        wrap.classList.remove('hidden');
      }, 3000);
    }

    window.addEventListener('appinstalled', function () {
      dismiss();
    });
  })();
</script>
