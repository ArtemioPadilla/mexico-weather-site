---
/**
 * PWA install prompt — handles two distinct paths:
 *
 * Android Chrome / Edge / Chromium: listens for beforeinstallprompt
 * and surfaces a discrete bottom-left "Instalar app" button.
 *
 * iOS Safari: doesn't fire beforeinstallprompt at all (#7.2). On the
 * 2nd+ session visit, surfaces a bottom-sheet with inline visual
 * instructions ("Toca Compartir → Añadir a pantalla de inicio").
 * Gated on visit count so first-time visitors aren't ambushed,
 * dismissible per-device via localStorage so the prompt doesn't
 * pester users who said no.
 */
---

{/* Chromium path — round button, shown when beforeinstallprompt fires */}
<div
  id="pwa-install-wrap"
  class="pointer-events-none fixed bottom-3 left-3 z-30 hidden"
  aria-live="polite"
>
  <button
    id="pwa-install-btn"
    type="button"
    class="pointer-events-auto inline-flex items-center gap-1.5 rounded-full bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white shadow-lg ring-2 ring-white/40 hover:bg-blue-500 dark:ring-gray-900/40"
    aria-label="Instalar Clima México como app"
  >
    <svg
      class="h-4 w-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"
      />
    </svg>
    Instalar app
  </button>
</div>

{/* iOS Safari path — bottom-sheet with inline instructions. Hidden
    by default; the script reveals it on 2nd+ session visit when not
    already installed and not previously dismissed. */}
<div
  id="ios-install-sheet"
  role="dialog"
  aria-labelledby="ios-install-h"
  aria-modal="false"
  class="pointer-events-none fixed bottom-0 left-0 right-0 z-40 hidden p-3"
>
  <div
    class="pointer-events-auto mx-auto max-w-md rounded-2xl bg-white p-4 shadow-2xl ring-1 ring-gray-200 dark:bg-gray-900 dark:ring-gray-800"
    style="padding-bottom: calc(env(safe-area-inset-bottom) + 1rem)"
  >
    <div class="flex items-start gap-3">
      <span aria-hidden="true" class="text-2xl leading-none">📱</span>
      <div class="flex-1">
        <h2
          id="ios-install-h"
          class="text-sm font-semibold text-gray-900 dark:text-gray-100"
        >
          Añade Clima México a tu pantalla de inicio
        </h2>
        <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
          Toca{' '}
          <svg
            class="-mb-0.5 inline-block h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-label="botón Compartir"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 4v12m0-12l-4 4m4-4l4 4M5 20h14"
            />
          </svg>
          <strong>Compartir</strong>, luego elige <strong
            >"Añadir a pantalla de inicio"</strong
          >.
        </p>
      </div>
      <button
        id="ios-install-dismiss"
        type="button"
        aria-label="Cerrar"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-800 dark:hover:text-gray-200"
        >✕</button
      >
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var DISMISS_KEY = 'mw:pwa-install-dismissed';
    var VISITS_KEY = 'mw:visits';
    /** sessionStorage flag — set on the first page-load of a session
     *  so subsequent in-session navigations don't re-increment the
     *  persistent visit counter. The intent of the counter is
     *  "distinct sessions", not "page-loads within a session". */
    var SESSION_KEY = 'mw:visit-counted';

    var wrap = document.getElementById('pwa-install-wrap');
    var btn = document.getElementById('pwa-install-btn');
    var sheet = document.getElementById('ios-install-sheet');
    var sheetDismiss = document.getElementById('ios-install-dismiss');

    function alreadyInstalled() {
      try {
        return (
          window.matchMedia('(display-mode: standalone)').matches ||
          /** @type {any} */ (window.navigator).standalone === true
        );
      } catch (e) {
        return false;
      }
    }
    function dismissed() {
      try {
        return localStorage.getItem(DISMISS_KEY) === '1';
      } catch (e) {
        return false;
      }
    }
    function persistDismiss() {
      try {
        localStorage.setItem(DISMISS_KEY, '1');
      } catch (e) {
        /* ignore */
      }
    }
    function bumpVisits() {
      try {
        var n = parseInt(localStorage.getItem(VISITS_KEY) || '0', 10) || 0;
        // Only count one bump per session. Without this, every
        // page-load (Inicio → Mapa → Pregunta) would push the user
        // straight into the iOS sheet after just three clicks on
        // their first visit — way too aggressive.
        if (sessionStorage.getItem(SESSION_KEY) === '1') return n;
        n += 1;
        localStorage.setItem(VISITS_KEY, String(n));
        sessionStorage.setItem(SESSION_KEY, '1');
        return n;
      } catch (e) {
        return 0;
      }
    }

    if (alreadyInstalled() || dismissed()) return;

    // Increment visits counter once per page-load. The iOS sheet
    // shows on the 2nd visit + later — gives first-time visitors a
    // clean experience without an immediate install nag.
    var visits = bumpVisits();

    var isIosSafari =
      /iphone|ipad|ipod/i.test(navigator.userAgent) &&
      !/crios|fxios|edgios/i.test(navigator.userAgent);

    // --- Chromium path ----------------------------------------------
    var deferred = null;
    if (wrap && btn) {
      window.addEventListener('beforeinstallprompt', function (e) {
        e.preventDefault();
        deferred = e;
        wrap.classList.remove('hidden');
      });
      btn.addEventListener('click', function () {
        if (!deferred) return;
        deferred.prompt();
        deferred.userChoice.then(function (choice) {
          if (choice && choice.outcome === 'accepted') {
            persistDismiss();
            wrap.classList.add('hidden');
          }
          deferred = null;
        });
      });
    }

    // --- iOS Safari path -------------------------------------------
    if (isIosSafari && sheet && sheetDismiss && visits >= 2) {
      // Delay reveal so it doesn't compete with first paint.
      setTimeout(function () {
        sheet.classList.remove('hidden');
      }, 2000);
      sheetDismiss.addEventListener('click', function () {
        sheet.classList.add('hidden');
        persistDismiss();
      });
    }

    window.addEventListener('appinstalled', function () {
      persistDismiss();
      if (wrap) wrap.classList.add('hidden');
      if (sheet) sheet.classList.add('hidden');
    });
  })();
</script>
