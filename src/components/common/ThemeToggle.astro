---
/**
 * ThemeToggle — Botón accesible que cicla entre los temas
 * Sistema → Claro → Oscuro → Sistema.
 *
 * - Persiste la elección en localStorage ('light' | 'dark' | 'system').
 * - Aplica el tema de inmediato alternando la clase `.dark` en <html>.
 * - En modo 'system' escucha cambios de `matchMedia` en vivo.
 * - La lógica anti-FOUC vive en el <head> de BaseLayout; este botón solo
 *   refleja y modifica el estado actual.
 *
 * Posición: fijo arriba a la derecha; no choca con el FeedbackFAB
 * (que es fijo abajo a la derecha).
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const tr = {
  es: {
    label: 'Cambiar tema',
    light: 'Claro',
    dark: 'Oscuro',
    system: 'Sistema',
  },
  en: {
    label: 'Toggle theme',
    light: 'Light',
    dark: 'Dark',
    system: 'System',
  },
}[lang];
---

<div class="fixed top-[calc(0.75rem+env(safe-area-inset-top))] right-5 z-50">
  <button
    id="theme-toggle-btn"
    type="button"
    aria-label={tr.label}
    title={tr.label}
    data-l-light={tr.light}
    data-l-dark={tr.dark}
    data-l-system={tr.system}
    data-l-label={tr.label}
    class="relative w-12 h-12 rounded-full flex items-center justify-center shadow-lg
           bg-white text-gray-700 ring-1 ring-gray-900/10
           hover:bg-gray-50 hover:ring-gray-900/20
           dark:bg-gray-800 dark:text-gray-200 dark:ring-white/10
           dark:hover:bg-gray-700 dark:hover:ring-white/20
           transition-all hover:scale-105 hover:shadow-xl
           motion-reduce:transition-none motion-reduce:hover:scale-100
           focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
  >
    <!-- Icono: Sistema (monitor) -->
    <svg
      data-theme-icon="system"
      class="w-5 h-5 hidden"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.8"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z"
      />
    </svg>
    <!-- Icono: Claro (sol) -->
    <svg
      data-theme-icon="light"
      class="w-5 h-5 hidden"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.8"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
      />
    </svg>
    <!-- Icono: Oscuro (luna) -->
    <svg
      data-theme-icon="dark"
      class="w-5 h-5 hidden"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.8"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
      />
    </svg>
    <span id="theme-toggle-sr" class="sr-only">{tr.label}</span>
  </button>
</div>

<script>
  import {
    THEME_STORAGE_KEY,
    normalizePreference,
    resolveTheme,
    nextPreference,
    type ThemePreference,
  } from '../../lib/theme';

  function initThemeToggle(): void {
    const btn = document.getElementById('theme-toggle-btn');
    const srLabel = document.getElementById('theme-toggle-sr');
    if (!btn) return;

    const labels: Record<ThemePreference, string> = {
      light: btn.dataset.lLight || 'Claro',
      dark: btn.dataset.lDark || 'Oscuro',
      system: btn.dataset.lSystem || 'Sistema',
    };
    const baseLabel = btn.dataset.lLabel || 'Cambiar tema';

    const mql = window.matchMedia('(prefers-color-scheme: dark)');

    function readPreference(): ThemePreference {
      let raw: string | null = null;
      try {
        raw = window.localStorage.getItem(THEME_STORAGE_KEY);
      } catch {
        /* localStorage no disponible (modo privado) → 'system' */
      }
      return normalizePreference(raw);
    }

    function applyResolved(pref: ThemePreference): void {
      const resolved = resolveTheme(pref, mql.matches);
      document.documentElement.classList.toggle('dark', resolved === 'dark');
    }

    function syncUI(pref: ThemePreference): void {
      const icons =
        btn!.querySelectorAll<SVGElement>('[data-theme-icon]');
      icons.forEach((icon) => {
        icon.classList.toggle(
          'hidden',
          icon.dataset.themeIcon !== pref,
        );
      });
      const full = `${baseLabel}: ${labels[pref]}`;
      btn!.setAttribute('aria-label', full);
      btn!.setAttribute('title', full);
      if (srLabel) srLabel.textContent = full;
    }

    function render(pref: ThemePreference): void {
      applyResolved(pref);
      syncUI(pref);
    }

    btn.addEventListener('click', () => {
      const next = nextPreference(readPreference());
      try {
        window.localStorage.setItem(THEME_STORAGE_KEY, next);
      } catch {
        /* sin persistencia: aplicar de todos modos para esta sesión */
      }
      render(next);
    });

    // Cuando la preferencia es 'system', reaccionar a cambios del SO en vivo.
    mql.addEventListener('change', () => {
      if (readPreference() === 'system') {
        render('system');
      }
    });

    // Sincronizar con cambios de tema en otras pestañas.
    window.addEventListener('storage', (e) => {
      if (e.key === THEME_STORAGE_KEY) render(normalizePreference(e.newValue));
    });

    // Sincronizar el estado inicial del botón (la clase .dark ya fue
    // fijada por el script anti-FOUC en el <head>).
    render(readPreference());
  }

  initThemeToggle();
</script>
